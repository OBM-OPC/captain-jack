---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import keelcrabFrontalSunshine from "../assets/images/keelcrab_frontal_sunshine.png";
import keelcrabOnBoat from "../assets/images/keelcrab_on_boat.png";
import ourHome from "../assets/images/our_home.jpg";
import ourStore from "../assets/images/our_store.jpg";

const painPoints = [
  {
    title: "Ausfallzeiten kosten Geld",
    text: "Jedes Boot, das wegen Bewuchs langsamer wird oder aus dem Betrieb genommen werden muss, belastet Ihre Auslastung, Ihre Planung und Ihren Umsatz.",
  },
  {
    title: "Flottenpflege muss planbar sein",
    text: "Charterer und Marinas brauchen feste Abläufe, schnelle Einsatzfenster und einen Dienstleister, der zuverlässig mitdenkt.",
  },
  {
    title: "Gäste und Eigner erwarten Standards",
    text: "Ein sichtbar gepflegter Rumpf steht für Qualität, geringeren Verbrauch und professionellen Betrieb – und stärkt Ihr Image vor Ort.",
  },
];

const solutions = [
  "Mobile Reinigung direkt am Liegeplatz oder nach Absprache an Ihrem Standort",
  "Schnelle Einsätze mit minimaler Unterbrechung des Charter- oder Marina-Betriebs",
  "Regelmäßige Flottenintervalle statt spontaner Einzelmaßnahmen",
  "Klare Kommunikation, verlässliche Terminfenster und kurze Reaktionswege",
  "Schonendes Verfahren ohne Kranen und ohne unnötige Logistikkosten",
  "Ein Partner in Preveza, der lokale Abläufe versteht und professionell umsetzt",
];

const b2bBenefits = [
  {
    title: "Mehr Verfügbarkeit",
    text: "Boote kommen schneller zurück in den Einsatz. Das ist besonders für Charterflotten ein direkter wirtschaftlicher Hebel.",
  },
  {
    title: "Bessere Performance",
    text: "Saubere Rümpfe unterstützen bessere Fahreigenschaften, geringeren Widerstand und einen effizienteren Betrieb.",
  },
  {
    title: "Weniger Koordinationsaufwand",
    text: "Sie arbeiten mit einem Ansprechpartner, der Einsätze organisiert, sauber abstimmt und verlässlich durchführt.",
  },
  {
    title: "Professioneller Eindruck",
    text: "Gepflegte Boote und saubere Prozesse zahlen direkt auf Ihre Wahrnehmung bei Gästen, Eignern und Partnern ein.",
  },
];

const processSteps = [
  {
    step: "01",
    title: "Bedarf verstehen",
    text: "Wir klären Flottengröße, Marina-Struktur, Einsatzfenster und Prioritäten – damit der Ablauf zu Ihrem Betrieb passt.",
  },
  {
    step: "02",
    title: "Intervall planen",
    text: "Gemeinsam definieren wir sinnvolle Reinigungszyklen für einzelne Boote, Charterflotten oder wiederkehrende Marina-Einsätze.",
  },
  {
    step: "03",
    title: "Vor Ort umsetzen",
    text: "Wir reinigen effizient direkt am Boot und halten die Unterbrechung Ihres Tagesgeschäfts so gering wie möglich.",
  },
  {
    step: "04",
    title: "Langfristig optimieren",
    text: "Aus Einzelaufträgen wird auf Wunsch ein verlässlicher B2B-Service mit planbaren Zeitfenstern und klaren Standards.",
  },
];
---

<Layout
  title="Für Charterflotten & Marinas"
  description="B2B-Bootsreinigung für Charterflotten und Marinas in Preveza: planbar, effizient und auf maximale Verfügbarkeit Ihrer Boote ausgelegt."
>
  <section class="relative flex min-h-[560px] items-center overflow-hidden py-20 pt-28 text-white lg:min-h-[560px] lg:py-28 lg:pt-32">
    <div class="absolute inset-0">
      <Image src={ourHome} alt="Captain Jack Standort in Preveza" width={1920} height={900} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0A2540]/95 via-[#0A2540]/80 to-[#0A2540]/62"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="mb-6 inline-flex items-center rounded-full border border-[#00c2d1]/40 bg-[#00c2d1]/10 px-4 py-2 text-sm font-medium text-[#00c2d1]">
          B2B-Lösungen für Preveza und Umgebung
        </div>
        <h1 class="mb-6 text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
          Für Charterflotten & Marinas
        </h1>
        <p class="mb-6 text-xl font-semibold text-[#00c2d1] md:text-2xl">
          Mehr Verfügbarkeit, weniger Stillstand, sauber organisierte Einsätze.
        </p>
        <p class="max-w-2xl text-lg leading-relaxed text-slate-300">
          Wenn Boote schnell wieder einsatzbereit sein müssen, braucht es mehr als nur Reinigung. Es braucht einen Partner,
          der Betriebsabläufe versteht, flexibel vor Ort arbeitet und Leistungen so organisiert, dass Ihre Flotte und Ihr Hafenbetrieb reibungslos weiterlaufen.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary btn-primary-lg">B2B-Gespräch anfragen</a>
          <a href="/keelcrab" class="btn-secondary btn-secondary-lg">Keelcrab für Flotten ansehen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Ihre Anforderungen</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Was Charterer und Marinas wirklich brauchen</h2>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {painPoints.map((point) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
            <h3 class="mb-4 text-2xl font-bold text-[#0A2540]">{point.title}</h3>
            <p class="leading-relaxed text-slate-600">{point.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8 lg:gap-16">
      <div class="overflow-hidden rounded-3xl shadow-2xl">
        <Image src={keelcrabFrontalSunshine} alt="Keelcrab für professionelle Flottenpflege" width={1100} height={900} class="h-full w-full object-cover" />
      </div>
      <div>
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Unsere Antwort</p>
        <h2 class="mb-6 text-3xl font-bold text-[#0A2540] md:text-4xl">So erfüllen wir diese Anforderungen professionell</h2>
        <ul class="space-y-4">
          {solutions.map((item) => (
            <li class="flex items-start gap-3 text-slate-700">
              <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">B2B-Vorteile</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Nicht nur sauber – wirtschaftlich sinnvoll</h2>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {b2bBenefits.map((benefit) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8">
            <h3 class="mb-3 text-2xl font-bold text-[#0A2540]">{benefit.title}</h3>
            <p class="leading-relaxed text-slate-600">{benefit.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#0A2540] py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Zusammenarbeit</p>
        <h2 class="text-3xl font-bold md:text-4xl">Von der Einzelleistung zum verlässlichen B2B-Service</h2>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        {processSteps.map((step) => (
          <div class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm">
            <p class="mb-4 text-sm font-medium tracking-[0.2em] text-[#00c2d1]">{step.step}</p>
            <h3 class="mb-3 text-2xl font-bold">{step.title}</h3>
            <p class="text-slate-300">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8 lg:gap-16">
      <div>
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Für wen das ideal ist</p>
        <h2 class="mb-6 text-3xl font-bold text-[#0A2540] md:text-4xl">Ideal für Unternehmen mit Anspruch an Betrieb, Standard und Geschwindigkeit</h2>
        <div class="space-y-4 text-lg leading-relaxed text-slate-600">
          <p>Unsere Lösung richtet sich an Charterunternehmen mit wiederkehrendem Turnover, an Marinas mit Qualitätsanspruch und an Betreiber, die ihren Kunden einen professionellen Eindruck bieten wollen.</p>
          <p>Besonders stark ist das Modell überall dort, wo mehrere Boote betreut werden, Zeitfenster eng sind und ein Dienstleister vor Ort nicht nur sauber arbeitet, sondern auch mitdenkt.</p>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl shadow-2xl">
        <Image src={ourStore} alt="Captain Jack Store und Service in Preveza" width={1000} height={800} class="h-full w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-20 text-white">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Nächster Schritt</p>
      <h2 class="text-3xl font-bold md:text-4xl">Lassen Sie uns Ihre Flotten- oder Marina-Anforderungen konkret besprechen</h2>
      <p class="mx-auto mt-5 max-w-3xl text-lg text-slate-300">
        Wir entwickeln keine Standardlösung von der Stange. Wir schauen auf Ihren Betrieb, Ihre Zeitfenster und Ihre Prioritäten – und machen daraus einen Service, der in der Praxis funktioniert.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="btn-primary btn-primary-lg">B2B-Termin anfragen</a>
        <a href="tel:+491754271476" class="btn-secondary btn-secondary-lg">Direkt sprechen</a>
      </div>
    </div>
  </section>
</Layout>
