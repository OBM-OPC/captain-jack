---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Leistungen" description="Captain Jack Leistungen — Storage, Parking, Service und Keelcrab Unterwasserreinigung in Preveza.">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Unsere Leistungen</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">Alles aus einer Hand</h1>
        <p class="text-lg text-slate-300">Storage, Parking, Service und Keelcrab® — alles, was Ihr Boot braucht, direkt hier in Preveza.</p>
      </div>
    </div>
  </section>

  <!-- Storage -->
  <section id="storage" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Storage</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Sichere Trockenlagerung</h2>
          <p class="text-gray-600 text-lg mb-6">
            Unsere klimatisierte Lagerhalle bietet maximalen Schutz für Ihre Wertgegenstände — rund um die Uhr, ganzjährig.
          </p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Feuer- und Wasseralarmsystem — mehrfache Sicherung</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Top-Sicherheitslage mit 24/7 Überwachung</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Ganzjährig verfügbar — auch in der Nebensaison</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Jeder Kunde erhält eine Nummer zur Identifizierung des Storages</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Spezial-Storage für ungewöhnliche Formen und Größen — auf Anfrage</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Sie können Ihre Gegenstände auch abholen lassen</span>
            </li>
          </ul>

          <!-- Pricing -->
          <div class="bg-gray-50 rounded-2xl p-6 space-y-4">
            <h3 class="text-lg font-bold text-gray-900">Preise</h3>
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="text-gray-700">Trockenbox auf Paletten</span>
              <span class="font-semibold text-[#00c2d1]">38 € / m³ pro Monat</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="text-gray-700">Exklusive Autos (indoor, Überwinterung)</span>
              <span class="font-semibold text-[#00c2d1]">225 € pro Monat</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-gray-700">Strom verfügbar</span>
              <span class="text-gray-500 text-sm">Auf Anfrage</span>
            </div>
          </div>

          <p class="text-sm text-gray-500 mt-4">Alles außer den genannten Preisen ist Sonderanfrage — wir finden eine Lösung.</p>
        </div>

        <!-- Right: Visual + Car Storage -->
        <div class="space-y-8">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-[#00c2d1]/20 to-[#00c2d1]/5 flex items-center justify-center border border-[#00c2d1]/20">
            <div class="text-center p-8">
              <svg class="w-16 h-16 text-[#00c2d1]/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              <p class="text-gray-400 text-sm">Lagerhalle (Foto folgt)</p>
            </div>
          </div>

          <!-- Car Storage Highlight -->
          <div class="bg-gradient-to-br from-amber-500/5 to-amber-500/10 rounded-2xl p-6 border border-amber-500/20">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-amber-500/15 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Exklusives Auto-Storage</h3>
                <p class="text-gray-600 text-sm">Indoor-Überwinterung für exklusive Fahrzeuge. 225 €/Monat inkl. Strom. Zusätzlich: Auto gelegentlich starten, Batterie prüfen und weiterer Service auf Wunsch.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Parking -->
  <section id="parking" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="order-2 lg:order-1">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-blue-400/10 to-cyan-400/10 flex items-center justify-center border border-gray-200">
            <div class="text-center p-8">
              <svg class="w-16 h-16 text-blue-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <p class="text-gray-400 text-sm">Stellplätze (Foto folgt)</p>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Parking</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Stellplätze für Boot & Camper</h2>
          <p class="text-gray-600 text-lg mb-6">
            Sichere Freifläche direkt am Standort — mit Überdachung ab kommenden Winter.
          </p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Grundsätzlich Freifläche — überdachte Plätze ab Winter 2026/27</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Boote und Camper willkommen</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Über 8 Meter: Sonderanfrage</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-[#00c2d1] rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-700">Mindestmietzeit: 1 Monat</span>
            </li>
          </ul>

          <!-- Pricing -->
          <div class="bg-white rounded-2xl p-6 shadow-sm space-y-4">
            <h3 class="text-lg font-bold text-gray-900">Preise</h3>
            <div class="flex justify-between items-center py-2 border-b border-gray-100">
              <span class="text-gray-700">Boot / Camper Stellplatz (bis 8 m)</span>
              <span class="font-semibold text-[#00c2d1]">125 € / Monat inkl. MwSt.</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-gray-700">Über 8 Meter</span>
              <span class="text-gray-500 text-sm">Sonderanfrage</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service -->
  <section id="service" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Service</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Wartung & Reparatur</h2>
        <p class="text-gray-600 text-lg mb-6">
          Professionelle Wartung, Reparaturen und saisonale Inspektionen — alles vor Ort in Preveza.
        </p>
        <div class="bg-[#00c2d1]/5 border border-[#00c2d1]/20 rounded-2xl p-6">
          <p class="text-gray-600 italic">
            Detaillierte Service-Beschreibungen folgen in Kürze. Kontaktieren Sie uns für individuelle Anfragen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Passendes Angebot gefunden?</h2>
      <p class="text-xl text-slate-300 mb-8">Schreiben Sie uns — wir erstellen gerne ein individuelles Angebot für Sie.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="btn-primary btn-primary-lg">Kontakt aufnehmen</a>
        <a href="/keelcrab" class="btn-secondary btn-secondary-lg">Keelcrab® Infos</a>
      </div>
    </div>
  </section>

</Layout>