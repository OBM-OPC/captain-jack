---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import saschaAndGoshia from '../assets/images/sascha_and_goshia.jpg';
import saschaWithCaptain from '../assets/images/sascha_with_captain.jpg';
import captain from '../assets/images/captain.jpg';
import ourStore from '../assets/images/our_store.jpg';
import prevezaPromenade from '../assets/images/preveza_promenade.png';
---

<Layout title="Über uns" description="Captain Jack — Ihr Partner für Bootslagerung, Parking und Keelcrab Unterwasserreinigung in Preveza, Griechenland.">

  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 text-white">
    <div class="absolute inset-0 opacity-25">
      <Image
        src={prevezaPromenade}
        alt="Preveza Promenade"
        width={1600}
        height={900}
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-[#0A2540]/70"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl text-left">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Über uns</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">Captain Jack — persönlich, flexibel und direkt in Preveza</h1>
        <p class="text-lg text-slate-300">
          Wir verbinden sichere Lagerung, flexible Stellplätze und moderne Keelcrab® Reinigung mit persönlichem Service vor Ort.
          Für Bootsbesitzer, Charterkunden und alle, die in Preveza eine verlässliche Lösung suchen.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Wer wir sind</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Ein Standort, kurze Wege und echter Ansprechpartner</h2>
          <div class="space-y-5 text-lg text-gray-600">
            <p>
              Captain Jack ist kein anonymer Hafenservice. Hinter dem Standort stehen Menschen, die direkt ansprechbar sind,
              schnell reagieren und pragmatische Lösungen finden.
            </p>
            <p>
              Ob Storage, Parking oder Keelcrab® Einsatz: Unser Ziel ist immer, Ihr Boot sicher unterzubringen,
              schnell wieder einsatzbereit zu machen und den gesamten Ablauf für Sie so einfach wie möglich zu halten.
            </p>
            <p>
              Gerade in Preveza ist das entscheidend: Viele Boote, viele Anforderungen, aber oft keine zentrale Lösung.
              Genau hier setzt Captain Jack an.
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-3xl shadow-xl">
          <Image
            src={saschaAndGoshia}
            alt="Sascha und Goshia bei Captain Jack"
            width={900}
            height={700}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 overflow-hidden rounded-3xl shadow-xl">
          <Image
            src={ourStore}
            alt="Captain Jack Standort und Lagerfläche"
            width={900}
            height={700}
            class="h-full w-full object-cover"
          />
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Unser Standort</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Direkt in Preveza, nah am Wasser und nah am Kunden</h2>
          <div class="space-y-5 text-lg text-gray-600">
            <p>
              Unser Standort in Preveza ist die Basis für sichere Lagerung, schnelle Organisation und flexible Einsätze.
              Von hier aus betreuen wir Boote direkt vor Ort und koordinieren auch mobile Keelcrab® Reinigungen.
            </p>
            <p>
              Das bedeutet für Sie: kurze Wege, direkte Kommunikation und ein Ansprechpartner, der die lokalen Bedingungen kennt.
            </p>
          </div>

          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="rounded-2xl bg-white p-5 border border-slate-200 shadow-sm">
              <p class="font-semibold text-[#0A2540]">Sicher gelagert</p>
              <p class="mt-2 text-gray-600">Überwachte Lagerung und planbare Stellplätze direkt am Standort.</p>
            </div>
            <div class="rounded-2xl bg-white p-5 border border-slate-200 shadow-sm">
              <p class="font-semibold text-[#0A2540]">Flexibel betreut</p>
              <p class="mt-2 text-gray-600">Schnelle Abstimmung für Reinigung, Parking und individuelle Lösungen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Was uns auszeichnet</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Warum Kunden mit Captain Jack arbeiten</h2>
        <p class="text-lg text-gray-600">Nicht wegen großer Worte, sondern weil Service, Erreichbarkeit und Umsetzung vor Ort stimmen.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        <div class="rounded-2xl bg-slate-50 border border-slate-200 p-8 shadow-sm">
          <h3 class="text-xl font-bold text-[#0A2540] mb-3">Persönlich erreichbar</h3>
          <p class="text-gray-600">Direkter Kontakt statt Umwege. Schnell, verbindlich und unkompliziert.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 border border-slate-200 p-8 shadow-sm">
          <h3 class="text-xl font-bold text-[#0A2540] mb-3">Moderne Technik</h3>
          <p class="text-gray-600">Mit Keelcrab® bieten wir eine smarte Alternative zu aufwendiger klassischer Reinigung.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 border border-slate-200 p-8 shadow-sm">
          <h3 class="text-xl font-bold text-[#0A2540] mb-3">Flexibler Einsatz</h3>
          <p class="text-gray-600">Nicht nur am eigenen Standort: Nach Absprache auch mobil im Hafen, am Liegeplatz oder am Anker.</p>
        </div>
        <div class="rounded-2xl bg-slate-50 border border-slate-200 p-8 shadow-sm">
          <h3 class="text-xl font-bold text-[#0A2540] mb-3">Alles aus einer Hand</h3>
          <p class="text-gray-600">Storage, Parking, Reinigung und Betreuung gebündelt an einem Ort.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
        <div>
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Keelcrab & Persönlichkeit</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Technik mit Charakter</h2>
          <div class="space-y-5 text-lg text-gray-600">
            <p>
              Captain Jack steht nicht nur für Technik und Infrastruktur, sondern auch für Wiedererkennbarkeit.
              Die Marke lebt von Persönlichkeit, Nahbarkeit und einem Auftritt, der im Hafen im Kopf bleibt.
            </p>
            <p>
              Genau deshalb gehört auch Captain, unser Hund und Maskottchen, ganz selbstverständlich dazu.
              Er bringt Charme in die Marke und sorgt dafür, dass Captain Jack nicht austauschbar wirkt.
            </p>
          </div>

          <div class="mt-8 rounded-3xl bg-white border border-slate-200 p-8 shadow-sm">
            <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Maskottchen</p>
            <p class="text-xl font-semibold text-[#0A2540] mb-3">"Captain gehört einfach dazu."</p>
            <p class="text-gray-600">
              Als treuer Begleiter und kleines Gesicht der Marke bringt Captain Wärme, Wiedererkennung und Persönlichkeit in den Hafenalltag.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
          <div class="overflow-hidden rounded-3xl shadow-xl">
            <Image
              src={saschaWithCaptain}
              alt="Sascha mit Captain"
              width={900}
              height={700}
              class="h-full w-full object-cover"
            />
          </div>
          <div class="overflow-hidden rounded-3xl shadow-xl max-w-md">
            <Image
              src={captain}
              alt="Captain der Hund und Maskottchen"
              width={700}
              height={700}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Lernen Sie Captain Jack persönlich kennen</h2>
      <p class="text-xl text-slate-300 mb-8">Wenn Sie in Preveza eine verlässliche Lösung für Storage, Parking oder Keelcrab® suchen, sprechen Sie mit uns.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="btn-primary btn-primary-lg">Jetzt Kontakt aufnehmen</a>
        <a href="/leistungen" class="btn-secondary btn-secondary-lg">Leistungen ansehen</a>
      </div>
    </div>
  </section>

</Layout>
