---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Storage" description="Trockenlagerung für Boote und Autos in Preveza. 24/7 Überwachung, klimatisierte Hallen, Top-Sicherheitslager.">
  <Navigation />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-blue-900 to-blue-800 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="inline-flex items-center px-4 py-2 bg-blue-700/50 rounded-full text-sm font-medium mb-6">
          Top-Sicherheitslager
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Storage</h1>
        <p class="text-xl text-blue-100">Trockenlagerung mit höchsten Sicherheitsstandards für Ihr Boot oder Auto in Preveza.</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Ihre Vorteile bei Captain Jack</h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">24/7 Überwachung</h3>
                <p class="text-gray-600">Rund um die Uhr Videoüberwachung für maximale Sicherheit Ihrer Wertsachen.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Wasser- & Feueralarmanlage</h3>
                <p class="text-gray-600">Moderne Alarmtechnik schützt vor Wasserschäden und Bränden.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 6h4"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Klimatisierte Halle</h3>
                <p class="text-gray-600">Optimale Temperaturen für Bootslacke und technische Ausrüstung.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-video rounded-2xl bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center">
            <div class="text-center">
              <div class="w-32 h-32 mx-auto bg-white/50 rounded-2xl flex items-center justify-center">
                <svg class="w-16 h-16 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
              </div>
              <p class="mt-4 text-gray-500">Bild: Lagerhalle (kommt vom Kunden)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Preise</h2>
        <p class="text-xl text-gray-600">Transparente Konditionen ohne versteckte Gebühren</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Box Storage -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900">Lagerboxen</h3>
          </div>
          
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-600 mb-2">38 €</div>
            <p class="text-gray-500">pro m³ / Monat</p>
          </div>
          
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              24/7 Überwachung
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Klimatisierte Halle
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Mindestlaufzeit: 1 Monat
            </li>
          </ul>
        </div>

        <!-- Car Storage -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-blue-200 relative">
          <div class="absolute top-0 right-0 bg-blue-600 text-white text-sm font-semibold px-4 py-1 rounded-bl-lg rounded-tr-2xl">
            Beliebt
          </div>
          
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900">Autolagerung (innen)</h3>
          </div>
          
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-600 mb-2">225 €</div>
            <p class="text-gray-500">pro Monat</p>
          </div>
          
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Premium Indoor-Platz
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Komplette Sicherheit
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Mindestlaufzeit: 1 Monat
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-blue-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-3xl font-bold mb-6">Reservieren Sie jetzt Ihren Stellplatz!</h2>
      <p class="text-xl text-blue-100 mb-8">Kontaktieren Sie Gosia für Verfügbarkeit und Buchung.</p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-white text-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-colors">
          Jetzt anrufen
        </a>
        <a href="/kontakt" class="inline-flex items-center px-8 py-4 bg-blue-700 text-white font-semibold rounded-lg hover:bg-blue-800 transition-colors border border-blue-500">
          Kontaktformular
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>