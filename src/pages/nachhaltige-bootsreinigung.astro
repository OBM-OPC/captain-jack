---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import keelcrabUnder from "../assets/images/keelcrab_under.png";
import keelcrabFrontalSunshine from "../assets/images/keelcrab_frontal_sunshine.png";
import raypath from "../assets/images/raypath.jpg";
import keelcrabPro from "../assets/images/keelcrab_pro.jpg";
import keelcrabGreece from "../assets/images/keelcrab_greece.jpg";
import keelcrabClose from "../assets/images/keelcrab_close.jpg";

const pillars = [
  {
    title: "Sauberer Rumpf, saubereres Wasser",
    text: "Keelcrab reinigt den Rumpf direkt im Wasser kontrolliert und effizient. Das System filtert unter anderem Mikroplastik und feine Partikel aus dem Reinigungsprozess heraus – für eine sichtbar saubere Lösung mit deutlich geringerer Belastung für Hafenbecken und Küstenwasser.",
  },
  {
    title: "Reinigung ohne aggressive Chemie",
    text: "Wir arbeiten bewusst mit einem Verfahren, das ohne klassische aggressive Reinigungschemie auskommt. Das schont Beschichtungen, reduziert Rückstände und sorgt für eine nachhaltigere Pflege des Unterwasserschiffs.",
  },
  {
    title: "Raypath als bewusste Ergänzung",
    text: "Bei unserer Reinigung setzen wir zusätzlich auf Produkte von Raypath.eu. Diese stehen für eine ressourcenschonende, langlebige und effektive Reinigungslösung – mit weniger Verbrauchsmaterial, weniger Einwegprodukten und einem hohen Sauberkeitsstandard.",
  },
];

const advantages = [
  "Filtration von Mikroplastik und feinen Partikeln während des Reinigungsprozesses",
  "Schonende Reinigung des Rumpfs ohne klassische aggressive Chemie",
  "Raypath-Produkte als wichtiger Baustein für nachhaltige Sauberkeit",
  "Weniger Logistikaufwand als bei klassischen Taucher- oder Auswasserungsverfahren",
  "Langfristig wirtschaftlich für Eigner, Charterbetriebe und Marinas",
  "Zukunftsfähige Technologie zur Sicherung qualifizierter Arbeitsplätze",
];

const regulationPoints = [
  "EU-Umweltvorgaben und lokale Auflagen betrachten unkontrollierten Abrieb im Wasser zunehmend kritisch.",
  "Traditionelle Reinigungsmethoden mit Tauchern geraten dadurch stärker unter Beobachtung – besonders dort, wo Rückstände nicht aufgefangen oder gefiltert werden.",
  "Mit Keelcrab setzen wir auf ein Verfahren, das technologische Kontrolle, Effizienz und Umweltbewusstsein zusammenbringt.",
];

const raypathBenefits = [
  "Weniger Verbrauchsmaterial im täglichen Einsatz.",
  "Langlebige Produkte statt kurzfristiger Wegwerf-Lösungen.",
  "Sauberkeit, die zur nachhaltigen Positionierung passt.",
  "Eine starke Ergänzung zum Keelcrab-Konzept.",
];

const regulationBenefits = [
  "Bessere Vorbereitung auf strengere Umweltauflagen.",
  "Mehr Sicherheit für Betreiber und Marina-Standorte.",
  "Klare Positionierung als moderner Dienstleister.",
  "Weniger Abhängigkeit von veralteten Methoden.",
];

const futureBenefits = [
  "Zukunftsfähige Technologie statt Übergangslösungen.",
  "Attraktiv für Eigner, Flotten und Marinas.",
  "Skalierbar für regelmäßige Einsätze und Wachstum.",
  "Ein stärkeres Markenbild durch Innovation.",
];

const jobsBenefits = [
  "Planbare Einsätze statt reaktiver Einzelaufträge.",
  "Qualifizierte Arbeit mit moderner Technik.",
  "Langfristig tragfähige Services für die Region.",
  "Bessere Perspektiven in einem wachsenden Feld.",
];
---

<Layout
  title="Nachhaltige Bootsreinigung"
  description="Nachhaltige Bootsreinigung mit Keelcrab bei Captain Jack: saubere Rümpfe, Mikroplastik-Filterung, Raypath-Produkte und ein zukunftsfähiger Service für Preveza."
>
  <section class="relative flex min-h-[560px] items-center overflow-hidden py-20 pt-28 text-white lg:min-h-[560px] lg:py-28 lg:pt-32">
    <div class="absolute inset-0">
      <Image src={keelcrabFrontalSunshine} alt="Keelcrab im Einsatz am Boot" width={1920} height={900} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0A2540]/95 via-[#0A2540]/82 to-[#0A2540]/62"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="mb-6 inline-flex items-center rounded-full border border-[#00c2d1]/40 bg-[#00c2d1]/10 px-4 py-2 text-sm font-medium text-[#00c2d1]">
          Verantwortungsvoll reinigen in Preveza
        </div>
        <h1 class="mb-6 text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
          Nachhaltige Bootsreinigung mit echter Wirkung
        </h1>
        <p class="mb-6 text-xl font-semibold text-[#00c2d1] md:text-2xl">
          Sauberer Rumpf. Weniger Belastung. Zukunftsfähige Technologie.
        </p>
        <p class="max-w-2xl text-lg leading-relaxed text-slate-300">
          Bei Captain Jack geht es nicht nur darum, Bewuchs zu entfernen. Wir setzen auf eine Reinigungsmethode,
          die Sauberkeit, Umweltverantwortung und wirtschaftliche Vernunft miteinander verbindet – mit Keelcrab
          und ergänzend mit den Reinigungslösungen von Raypath.eu.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary btn-primary-lg">Nachhaltige Reinigung anfragen</a>
          <a href="/keelcrab" class="btn-secondary btn-secondary-lg">Mehr zu Keelcrab</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Warum das wichtig ist</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Nachhaltigkeit heißt für uns: sichtbar sauber und systemisch sinnvoll</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {pillars.map((pillar) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
            <h3 class="mb-4 text-2xl font-bold text-[#0A2540]">{pillar.title}</h3>
            <p class="leading-relaxed text-slate-600">{pillar.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8 lg:gap-16">
      <div class="space-y-6 lg:order-1">
        <div class="overflow-hidden rounded-3xl shadow-xl">
          <Image src={keelcrabUnder} alt="Keelcrab unter Wasser am Rumpf" width={900} height={650} class="h-full w-full object-cover" />
        </div>
        <div class="overflow-hidden rounded-3xl shadow-xl">
          <Image src={keelcrabClose} alt="Keelcrab Technologie Nahaufnahme" width={900} height={500} class="h-full w-full object-cover" />
        </div>
      </div>

      <div class="lg:order-2">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Technologie & Sauberkeit</p>
        <h2 class="mb-6 text-3xl font-bold text-[#0A2540] md:text-4xl">Keelcrab und Raypath: eine moderne Kombination</h2>
        <p class="mb-6 text-lg leading-relaxed text-slate-600">
          Keelcrab ermöglicht eine kontrollierte Unterwasserreinigung direkt am Boot. Für ergänzende Reinigungsarbeiten setzen wir auf Raypath-Produkte,
          weil sie zu unserem Anspruch passen: hohe Reinigungsleistung, weniger Verbrauchsmaterial und eine Lösung, die langfristig sinnvoll ist.
        </p>
        <ul class="space-y-3">
          {advantages.map((item) => (
            <li class="flex items-start gap-3 text-slate-700">
              <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#28a745]">Raypath</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Raypath bekommt bewusst einen eigenen Platz im Konzept</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-16">
        <div>
          <div class="space-y-5 text-lg leading-relaxed text-slate-600">
            <p>Raypath ist für uns nicht nur ein Zusatzprodukt, sondern ein klarer Baustein innerhalb eines nachhaltig gedachten Reinigungsprozesses. Wenn wir von moderner Bootsreinigung sprechen, geht es nicht nur um das Unterwasserschiff, sondern um den gesamten Qualitätsanspruch rund um Sauberkeit, Pflege und Werterhalt.</p>
            <p>Darum bekommt Raypath bei Captain Jack einen eigenen Abschnitt: weil die Produkte unsere Haltung unterstützen — langlebig arbeiten, Ressourcen schonen und sichtbare Ergebnisse liefern.</p>
            <p>So entsteht ein stimmiges Gesamtbild: moderne Technik im Wasser, saubere ergänzende Prozesse an Bord und ein klarer Qualitätsanspruch, der auf der ganzen Seite nachvollziehbar wird.</p>
          </div>

          <div class="mt-8">
            <h3 class="mb-5 text-2xl font-bold text-[#0A2540]">Was Raypath hier konkret verbessert</h3>
            <ul class="space-y-4 text-slate-700">
              {raypathBenefits.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#28a745] text-white">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="self-stretch overflow-hidden rounded-3xl shadow-xl min-h-[320px] lg:min-h-full">
          <Image src={raypath} alt="Raypath Produkte für nachhaltige Sauberkeit" width={900} height={700} class="h-full min-h-[320px] w-full object-cover lg:min-h-full" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Regulierung</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Regulierung macht nachhaltige Reinigung immer relevanter</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:gap-16">
        <div class="self-stretch overflow-hidden rounded-3xl shadow-xl min-h-[320px] lg:order-1 lg:min-h-full">
          <Image src={keelcrabGreece} alt="Keelcrab Reinigung in Griechenland" width={900} height={700} class="h-full min-h-[320px] w-full object-cover lg:min-h-full" />
        </div>

        <div class="lg:order-2">
          <div class="space-y-4 text-lg leading-relaxed text-slate-600">
            {regulationPoints.map((point) => (
              <p>{point}</p>
            ))}
            <p>Wer hier früh auf saubere, kontrollierbare Verfahren setzt, ist kommunikativ und operativ deutlich besser aufgestellt — gegenüber Kunden, Partnern und künftigen Anforderungen im Markt.</p>
          </div>

          <div class="mt-8">
            <h3 class="mb-5 text-2xl font-bold text-[#0A2540]">Was das für Betreiber einfacher macht</h3>
            <ul class="space-y-4 text-slate-700">
              {regulationBenefits.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#00c2d1] text-white">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Zukunft</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Wer heute umdenkt, ist morgen klar im Vorteil</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-16">
        <div>
          <div class="space-y-5 text-lg leading-relaxed text-slate-600">
            <p>Nachhaltige Reinigung ist kein kurzfristiger Trend. Sie wird zur Erwartung — bei Eignern, bei professionellen Flotten und bei Standorten, die ihren Qualitätsstandard sichtbar nach außen tragen wollen.</p>
            <p>Mit Keelcrab und einem durchdachten Gesamtkonzept positioniert sich Captain Jack frühzeitig in einem Bereich, der in den nächsten Jahren deutlich an Bedeutung gewinnen wird.</p>
            <p>Das schafft Vertrauen, hebt den Betrieb vom Wettbewerb ab und macht die Leistung auch langfristig wirtschaftlich interessant.</p>
          </div>

          <div class="mt-8">
            <h3 class="mb-5 text-2xl font-bold text-[#0A2540]">Worin der langfristige Vorteil liegt</h3>
            <ul class="space-y-4 text-slate-700">
              {futureBenefits.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="self-stretch overflow-hidden rounded-3xl shadow-xl min-h-[320px] lg:min-h-full">
          <Image src={keelcrabPro} alt="Professionelle Keelcrab Bootsreinigung" width={900} height={700} class="h-full min-h-[320px] w-full object-cover lg:min-h-full" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Arbeitsplätze</p>
        <h2 class="text-3xl font-bold text-[#0A2540] md:text-4xl">Zukunftsfähige Technik schafft auch bessere Arbeit</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:gap-16">
        <div class="self-stretch overflow-hidden rounded-3xl shadow-xl min-h-[320px] lg:order-1 lg:min-h-full">
          <Image src={keelcrabUnder} alt="Keelcrab Unterwasserreinigung" width={900} height={700} class="h-full min-h-[320px] w-full object-cover lg:min-h-full" />
        </div>

        <div class="lg:order-2">
          <div class="space-y-5 text-lg leading-relaxed text-slate-600">
            <p>Wir sind überzeugt: Wer in moderne Reinigungstechnologie investiert, sichert nicht nur saubere Boote, sondern baut zugleich ein professionelleres und stabileres Service-Modell auf. Das ist wichtig für Betriebe, für Mitarbeiter und für die Region.</p>
            <p>Statt veraltete Methoden nur zu verwalten, entstehen mit klaren Prozessen, moderner Technik und wachsender Nachfrage neue Chancen für qualifizierte maritime Dienstleistungen.</p>
            <p>So wird Nachhaltigkeit nicht nur zum Umweltargument, sondern auch zu einer echten wirtschaftlichen Perspektive für Menschen, die in diesem Bereich arbeiten.</p>
          </div>

          <div class="mt-8">
            <h3 class="mb-5 text-2xl font-bold text-[#0A2540]">Warum das auch wirtschaftlich trägt</h3>
            <ul class="space-y-4 text-slate-700">
              {jobsBenefits.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#00c2d1] text-white">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-8 rounded-2xl border border-[#00c2d1]/20 bg-white p-6">
              <p class="text-sm font-medium uppercase tracking-[0.18em] text-[#00c2d1]">Captain Jack Anspruch</p>
              <p class="mt-3 text-lg font-semibold text-[#0A2540]">Professionelle Reinigung mit Verantwortung – für Boote, Gewässer und die Zukunft des maritimen Service.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-20 text-white">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Jetzt anfragen</p>
      <h2 class="text-3xl font-bold md:text-4xl">Sie möchten nachhaltiger reinigen – ohne Kompromisse bei der Qualität?</h2>
      <p class="mx-auto mt-5 max-w-3xl text-lg text-slate-300">
        Dann sprechen Sie mit uns. Wir zeigen Ihnen, wie eine moderne Bootsreinigung in Preveza heute aussehen sollte:
        effizient, sauber, professionell und langfristig tragfähig.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="btn-primary btn-primary-lg">Beratung anfragen</a>
        <a href="tel:+306984477868" class="btn-secondary btn-secondary-lg">Direkt anrufen</a>
      </div>
    </div>
  </section>
</Layout>
