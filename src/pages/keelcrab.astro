---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import keelcrabFront from "../assets/images/keelcrab_front.png";
import keelcrabOnBoat from "../assets/images/keelcrab_on_boat.png";

const benefits = [
  {
    title: "Weniger Kraftstoffverbrauch",
    text: "Bis zu 20% Einsparung durch sauberen Rumpf",
  },
  {
    title: "Kein Kranen notwendig",
    text: "Reinigung erfolgt direkt im Wasser",
  },
  {
    title: "Mehr Leistung & Effizienz",
    text: "Sauberer Rumpf = bessere Geschwindigkeit",
  },
  {
    title: "Live-Inspektion",
    text: "Fotos & Videos direkt auf dein Gerät",
  },
];

const steps = [
  {
    title: "Einsatz vor Ort",
    text: "Der Roboter wird direkt am Boot ins Wasser gesetzt",
  },
  {
    title: "Reinigung & Inspektion",
    text: "Bürsten entfernen Bewuchs, Kamera überprüft den Zustand",
  },
  {
    title: "Auswertung",
    text: "Du erhältst Bilder und Einblicke zum Rumpfzustand",
  },
];

const technologyPoints = [
  "Ferngesteuerte Unterwasser-Drohne",
  "Für Salz- und Süßwasser geeignet",
  "Zertifizierte Nylon- und Edelstahlbürsten",
  "Schonend für Antifouling-Beschichtung",
];

const audiences = [
  {
    title: "Segelboote & Motorboote",
    text: "Bis ca. 25 Meter Länge",
  },
  {
    title: "Privatbesitzer & Marinas",
    text: "Ideal für regelmäßige Wartung",
  },
];
---

<Layout
  title="Keelcrab Bootsrumpf-Reinigung"
  description="Bootsrumpf-Reinigung im Wasser mit Keelcrab: effizient, umweltfreundlich und ohne Kranen – direkt bei Captain Jack."
>
  <section class="relative overflow-hidden bg-gradient-to-br from-[#0A2540] via-[#12385a] to-[#0A2540] py-20 text-white lg:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(0,194,209,0.18),_transparent_35%)]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div class="mb-6 inline-flex items-center rounded-full border border-[#00c2d1]/40 bg-[#00c2d1]/10 px-4 py-2 text-sm font-medium text-[#00c2d1]">
            Unterwasserreinigung ohne Auswasserung
          </div>
          <h1 class="mb-4 text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
            Bootsrumpf-Reinigung im Wasser mit Keelcrab
          </h1>
          <p class="mb-4 text-xl font-semibold text-[#00c2d1] md:text-2xl">
            Effizient. Umweltfreundlich. Ohne Kranen.
          </p>
          <p class="max-w-2xl text-lg leading-relaxed text-slate-300">
            Keelcrab ist ein innovatives Unterwasser-Drohnen-System zur Reinigung und Inspektion von
            Bootsrümpfen – direkt im Wasser. Keine Auswasserung, keine Chemie, keine Ausfallzeiten.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/kontakt" class="btn-primary">Termin anfragen</a>
            <a href="/kontakt" class="btn-secondary">Kontakt aufnehmen</a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 rounded-[2rem] bg-[#00c2d1]/15 blur-3xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-4 shadow-2xl backdrop-blur-sm">
            <Image
              src={keelcrabFront}
              alt="Keelcrab Unterwasser-Drohne zur Bootsrumpf-Reinigung"
              width={900}
              height={900}
              class="h-full w-full rounded-[1.5rem] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Vorteile</p>
        <h2 class="text-3xl font-bold text-gray-900 md:text-4xl">Warum Keelcrab?</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        {benefits.map((benefit) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-bold text-[#0A2540]">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Ablauf</p>
        <h2 class="text-3xl font-bold text-gray-900 md:text-4xl">So läuft die Reinigung ab</h2>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {steps.map((step, index) => (
          <div class="relative overflow-hidden rounded-3xl bg-white p-8 shadow-sm border border-slate-200">
            <div class="absolute right-6 top-5 text-6xl font-bold leading-none text-slate-100">
              {String(index + 1).padStart(2, "0")}
            </div>
            <div class="relative">
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#0A2540] text-white">
                <span class="text-lg font-bold">{index + 1}</span>
              </div>
              <h3 class="mb-3 text-2xl font-bold text-[#0A2540]">{step.title}</h3>
              <p class="text-gray-600">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="order-2 lg:order-1">
          <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Technologie</p>
          <h2 class="mb-6 text-3xl font-bold text-gray-900 md:text-4xl">Moderne Unterwasser-Technologie</h2>
          <div class="space-y-4">
            {technologyPoints.map((point) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-600">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-lg text-gray-700">{point}</p>
              </div>
            ))}
          </div>

          <div class="mt-8 rounded-2xl border border-[#00c2d1]/20 bg-gradient-to-r from-[#00c2d1]/10 to-[#00c2d1]/5 p-6">
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-[#00c2d1]">Highlight</p>
            <p class="text-xl font-bold text-[#0A2540]">Abdeckung bis zu 20 m (mit Ultraschall-System)</p>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div class="overflow-hidden rounded-[2rem] shadow-xl ring-1 ring-slate-200">
            <Image
              src={keelcrabOnBoat}
              alt="Keelcrab am Boot im Einsatz"
              width={1200}
              height={900}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#0A2540] py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Vergleich</p>
        <h2 class="text-3xl font-bold md:text-4xl">Traditionelle Reinigung vs. Keelcrab</h2>
      </div>

      <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 backdrop-blur-sm">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="border-b border-white/10 p-8 md:border-b-0 md:border-r">
            <h3 class="mb-6 text-2xl font-bold text-white">Klassisch</h3>
            <ul class="space-y-4 text-slate-300">
              <li>Boot muss aus dem Wasser</li>
              <li>Hohe Kosten</li>
              <li>Zeitaufwendig</li>
              <li>Chemische Mittel</li>
            </ul>
          </div>
          <div class="p-8">
            <h3 class="mb-6 text-2xl font-bold text-[#00c2d1]">Keelcrab</h3>
            <ul class="space-y-4 text-white">
              <li class="flex items-center gap-3"><span class="text-emerald-400">✓</span>Reinigung im Wasser</li>
              <li class="flex items-center gap-3"><span class="text-emerald-400">✓</span>Kosteneffizient</li>
              <li class="flex items-center gap-3"><span class="text-emerald-400">✓</span>Schnell</li>
              <li class="flex items-center gap-3"><span class="text-emerald-400">✓</span>Umweltfreundlich</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Zielgruppe</p>
        <h2 class="mb-12 text-3xl font-bold text-gray-900 md:text-4xl">Für wen ist Keelcrab geeignet?</h2>
      </div>

      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
        {audiences.map((audience) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8 text-left shadow-sm">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="mb-2 text-xl font-bold text-[#0A2540]">{audience.title}</h3>
            <p class="text-gray-600">{audience.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-br from-[#0A2540] via-[#12385a] to-[#0A2540] py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl rounded-[2rem] border border-white/10 bg-white/5 px-8 py-12 text-center shadow-xl backdrop-blur-sm md:px-12">
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-[#00c2d1]">Jetzt anfragen</p>
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Halte deinen Bootsrumpf dauerhaft sauber</h2>
        <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-300">
          Buche jetzt deine Reinigung und Inspektion.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/kontakt" class="btn-primary">Termin anfragen</a>
          <a href="/kontakt" class="btn-secondary">Kontakt aufnehmen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
