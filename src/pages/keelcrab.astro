---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Keelcrab" description="Exklusiver Keelcrab Partner in Griechenland. Innovative Rumpfreinigung ohne Chemie, ohne Heben. 20-30% Kraftstoffeinsparung.">
  <Navigation />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-20 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 w-96 h-96 bg-blue-400/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-amber-400/20 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium mb-6 backdrop-blur-sm text-amber-300">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Exklusiver Partner in Griechenland
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">Keelcrab</h1>
          
          <p class="text-xl text-blue-100 mb-8">Die innovative Rumpfreinigung – im Wasser, ohne Chemie, mit echten Ergebnissen. Als exklusiver Keelcrab Partner bringen wir die Zukunft der Bootspflege nach Griechenland.</p>
          
          <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-lg">
            Termin vereinbaren
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="relative">
          <div class="aspect-square rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-56 h-56 mx-auto bg-gradient-to-br from-blue-500 to-amber-500 rounded-3xl flex items-center justify-center shadow-2xl">
                <div class="text-center">
                  <svg class="w-24 h-24 mx-auto text-white mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                  <span class="text-white font-bold text-xl tracking-wider">KEELCRAB</span>
                </div>
              </div>
              <p class="mt-6 text-blue-100">Bild: Keelcrab Maschine (kommt vom Kunden)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 Key Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">5 Gründe für Keelcrab</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Warum Bootsbesitzer auf Keelcrab setzen</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        <!-- Point 1 -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-6 text-center h-full">
          <div class="w-14 h-14 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-4">
            <span class="text-white font-bold text-xl">1</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Im Wasser reinigen</h3>
          <p class="text-gray-600 text-sm">Ihr Boot bleibt im Wasser – kein Heben, kein Trockendock nötig.</p>
        </div>

        <!-- Point 2 -->
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-2xl p-6 text-center h-full">
          <div class="w-14 h-14 bg-amber-500 rounded-full mx-auto flex items-center justify-center mb-4">
            <span class="text-white font-bold text-xl">2</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Keine Chemie</h3>
          <p class="text-gray-600 text-sm">100% umweltfreundlich – schützt Meereslebewesen und Riffe.</p>
        </div>

        <!-- Point 3 -->
        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-6 text-center h-full">
          <div class="w-14 h-14 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-4">
            <span class="text-white font-bold text-xl">3</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Schonend</h3>
          <p class="text-gray-600 text-sm">Schont das Rumpfgelcoat – keine Kratzer oder Beschädigungen.</p>
        </div>

        <!-- Point 4 -->
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-2xl p-6 text-center h-full">
          <div class="w-14 h-14 bg-amber-500 rounded-full mx-auto flex items-center justify-center mb-4">
            <span class="text-white font-bold text-xl">4</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Energieeffizient</h3>
          <p class="text-gray-600 text-sm">Nur 800 Watt Stromverbrauch – extrem ressourcenschonend.</p>
        </div>

        <!-- Point 5 -->
        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-6 text-center h-full">
          <div class="w-14 h-14 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-4">
            <span class="text-white font-bold text-xl">5</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Kraftstoff sparen</h3>
          <p class="text-gray-600 text-sm">20-30% weniger Verbrauch durch sauberen Rumpf.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile Service -->
  <section class="py-20 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium mb-6 text-amber-300">
            Mobiler Service
          </div>
          
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Wir kommen zu Ihnen</h2>
          
          <p class="text-xl text-blue-100 mb-6">Unser Keelcrab-Service ist mobil – wir reinigen Ihr Boot direkt vor Ort, egal wo Sie liegen.</p>
          
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Ankerplätze</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Marinas & Häfen</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Ganze Region Preveza</span>
            </li>
          </ul>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-48 h-48 mx-auto bg-gradient-to-br from-amber-500/50 to-blue-500/50 rounded-2xl flex items-center justify-center border-2 border-white/30">
                <svg class="w-24 h-24 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="mt-6 text-blue-100">Bild: Mobiler Service (kommt vom Kunden)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Charter Companies -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 rounded-3xl p-8 md:p-12 text-white">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium mb-6 text-amber-300">
              Für Charterflotten
            </div>
            
            <h2 class="text-3xl font-bold mb-4">Spezial für Charter Companies</h2>
            
            <p class="text-xl text-blue-100 mb-6">Superschnelle Reinigung für Charterflotten – damit Ihre Boote immer einsatzbereit sind.</p>
            
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Schnelle Durchlaufzeiten</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Ideale Ergebnisse zwischen den Chartertouren</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Sonderkonditionen für Flotten</span>
              </li>
            </ul>
          </div>

          <div class="text-center lg:text-right">
            <a href="/kontakt" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-lg">
              Angebot für Flotten anfragen
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Info -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Preise</h2>
        <p class="text-xl text-gray-600">Fair & transparent – nach Bootslänge, nicht nach Stunde</p>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div class="p-6">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Preisberechnung</h3>
            <p class="text-gray-600">Nach Länge, nicht nach Zeit</p>
          </div>

          <div class="p-6 border-x border-gray-100">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Dauer</h3>
            <p class="text-gray-600">Ca. 1-3 Stunden</p>
          </div>

          <div class="p-6">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Angebot</h3>
            <p class="text-gray-600">Individuelles Angebot</p>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-gray-100 text-center">
          <p class="text-gray-600 mb-4">Für ein individuelles Angebot kontaktieren Sie uns direkt.</p>
          <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
            Angebot anfragen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-3xl font-bold mb-6">Bereit für den saubersten Rumpf?</h2>
      <p class="text-xl text-blue-100 mb-8">Kontaktieren Sie Gosia direkt – wir machen Ihr Boot fit für die Saison.</p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-lg">
          <svg class="mr-2 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          +30 698 447 7868
        </a>
        <a href="https://wa.me/306984477868" target="_blank" rel="noopener" class="inline-flex items-center px-8 py-4 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors shadow-lg">
          <svg class="mr-2 w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 5.834h-.004a9.311 9.311 0 01-21-21c0-3.026.987-5.828 2.657-8.1l-1.423-5.618 5.649 1.42A9.293 9.293 0 0112 2a9.293 9.293 0 019.293 9.293 9.311 9.311 0 01-9.293 9.292z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
