---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontakt" description="Kontaktieren Sie Captain Jack in Preveza. Gosia spricht Deutsch und Griechisch. Erreichbar per Telefon, WhatsApp und Formular.">

  <!-- Hero -->
  <section class="relative flex min-h-[560px] items-center bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 text-white">
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-3xl text-left">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Kontakt</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">Sprechen Sie uns an</h1>
        <p class="text-lg text-slate-300">Wir sprechen Deutsch und Englisch. Schnelle Antwort, persönliche Beratung.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Contact Options + Form -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Direkt erreichen</h2>

          <!-- Phone DE -->
          <a href="tel:+491754271476" class="block bg-gray-50 rounded-2xl p-6 hover:shadow-lg transition-all duration-200 group mb-4">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-blue-200 transition-colors">
                <svg class="w-7 h-7 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Deutsch / English</h3>
                <p class="text-2xl font-bold text-blue-600 mt-1">+49 175 4271476</p>
                <p class="text-gray-500 mt-2">Auch per WhatsApp erreichbar</p>
              </div>
            </div>
          </a>

          <!-- Phone GR -->
          <a href="tel:+306984477868" class="block bg-gray-50 rounded-2xl p-6 hover:shadow-lg transition-all duration-200 group mb-4">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-200 transition-colors">
                <svg class="w-7 h-7 text-emerald-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Griechenland</h3>
                <p class="text-2xl font-bold text-emerald-600 mt-1">+30 698 447 7868</p>
                <p class="text-gray-500 mt-2">Auch per WhatsApp erreichbar</p>
              </div>
            </div>
          </a>

          <!-- WhatsApp Button -->
          <a href="https://wa.me/306984477868" target="_blank" rel="noopener" class="block bg-green-500 rounded-2xl p-6 hover:shadow-lg hover:bg-green-600 transition-all duration-200 active:scale-[0.97] mb-8">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
              </div>
              <div class="text-white">
                <h3 class="text-lg font-semibold">WhatsApp</h3>
                <p class="text-green-100">Schnell & unkompliziert schreiben</p>
              </div>
              <svg class="ml-auto w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>

          <!-- Contact Form -->
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Oder schreiben Sie uns</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#00c2d1] focus:ring-1 focus:ring-[#00c2d1] outline-none transition-colors" placeholder="Ihr Name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#00c2d1] focus:ring-1 focus:ring-[#00c2d1] outline-none transition-colors" placeholder="ihre@email.de" />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Betreff</label>
              <select id="subject" name="subject" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#00c2d1] focus:ring-1 focus:ring-[#00c2d1] outline-none transition-colors">
                <option value="">Bitte wählen...</option>
                <option value="storage">Storage</option>
                <option value="parking">Parking</option>
                <option value="keelcrab">Keelcrab Reinigung</option>
                <option value="service">Service & Wartung</option>
                <option value="sonstiges">Sonstiges</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Nachricht</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#00c2d1] focus:ring-1 focus:ring-[#00c2d1] outline-none transition-colors" placeholder="Wie können wir Ihnen helfen?"></textarea>
            </div>
            <button type="submit" class="btn-primary btn-primary-md w-full">Nachricht senden</button>
          </form>
        </div>

        <!-- Right: Location -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Standort</h2>

          <div class="space-y-6 mb-8">
            <div class="bg-gray-50 rounded-2xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900">Hauptstandort</h3>
                  <address class="not-italic text-gray-600 mt-2">
                    Leofóros Ioanninon 215<br/>
                    Preveza Stadthafen<br/>
                    Griechenland
                  </address>
                </div>
              </div>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="aspect-video rounded-2xl bg-gray-200 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto bg-gray-300 rounded-full flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <p class="text-gray-500">Google Maps wird hier eingebunden</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>