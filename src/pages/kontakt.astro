---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Kontakt" description="Kontaktieren Sie Captain Jack in Preveza. Gosia spricht Deutsch und Griechisch. Erreichbar per Telefon und WhatsApp.">
  <Navigation />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-blue-900 to-blue-800 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Kontakt</h1>
        <p class="text-xl text-blue-100">Wir freuen uns auf Ihre Nachricht! Gosia ist für Sie da – auf Deutsch oder Griechisch.</p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Cards -->
        <div class="space-y-6">
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Direkt erreichen</h2>
          
          <!-- Phone DE -->
          <a href="tel:+4917523456789" class="block bg-gray-50 rounded-2xl p-6 hover:shadow-lg transition-all duration-200 group">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-blue-200 transition-colors">
                <svg class="w-7 h-7 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Gosia (Deutsch)</h3>
                <p class="text-2xl font-bold text-blue-600 mt-1">+49 175 ...</p>
                <p class="text-gray-500 mt-2">Auch per WhatsApp erreichbar</p>
              </div>
            </div>
          </a>

          <!-- Phone GR -->
          <a href="tel:+306984477868" class="block bg-gray-50 rounded-2xl p-6 hover:shadow-lg transition-all duration-200 group">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-green-200 transition-colors">
                <svg class="w-7 h-7 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 5.834h-.004a9.311 9.311 0 01-21-21c0-3.026.987-5.828 2.657-8.1l-1.423-5.618 5.649 1.42A9.293 9.293 0 0112 2a9.293 9.293 0 019.293 9.293 9.311 9.311 0 01-9.293 9.292z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Gosia (Griechisch)</h3>
                <p class="text-2xl font-bold text-green-600 mt-1">+30 698 447 7868</p>
                <p class="text-gray-500 mt-2">Auch per WhatsApp erreichbar</p>
              </div>
            </div>
          </a>

          <!-- WhatsApp Button -->
          <a href="https://wa.me/306984477868" target="_blank" rel="noopener" class="block bg-green-500 rounded-2xl p-6 hover:shadow-lg hover:bg-green-600 transition-all duration-200 active:scale-[0.97]">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 5.834h-.004a9.311 9.311 0 01-21-21c0-3.026.987-5.828 2.657-8.1l-1.423-5.618 5.649 1.42A9.293 9.293 0 0112 2a9.293 9.293 0 019.293 9.293 9.311 9.311 0 01-9.293 9.292z"/>
                </svg>
              </div>
              <div class="text-white">
                <h3 class="text-lg font-semibold">WhatsApp</h3>
                <p class="text-green-100">Schnell & unkompliziert schreiben</p>
              </div>
              <svg class="ml-auto w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        </div>

        <!-- Location -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Standort</h2>
          
          <div class="space-y-6">
            <div class="bg-gray-50 rounded-2xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900">Hauptstandort</h3>
                  <address class="not-italic text-gray-600 mt-2">
                    Leofóros Ioanninon 215<br/>
                    Preveza Stadthafen<br/>
                    Griechenland
                  </address>
                </div>
              </div>
            </div>

            <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 bg-blue-400 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900">Zweiter Standort (ab nächste Woche)</h3>
                  <p class="text-gray-600 mt-2">Preveza Marina</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="mt-8 aspect-video rounded-2xl bg-gray-200 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto bg-gray-300 rounded-full flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="text-gray-500">Google Maps wird hier eingebunden</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Opening Hours -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-gray-900">Schnelle Terminvereinbarung</h2>
          <p class="text-gray-600 mt-2">Kontaktieren Sie uns direkt – wir melden uns schnellstmöglich bei Ihnen.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div class="p-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <p class="font-medium text-gray-900">Keelcrab Termine</p>
          </div>

          <div class="p-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <p class="font-medium text-gray-900">Storage & Parking</p>
          </div>

          <div class="p-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full mx-auto flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <p class="font-medium text-gray-900">Fragen & Beratung</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>