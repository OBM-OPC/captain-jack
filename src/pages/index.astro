---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Startseite" description="Captain Jack - Ihr zuverlässiger Partner für Bootslagerung, Parking und Keelcrab Rumpfreinigung in Preveza, Griechenland">
  <Navigation />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-blue-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center px-4 py-2 bg-blue-700/50 rounded-full text-sm font-medium text-blue-100">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Exklusiver Keelcrab Partner Griechenland
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
            Ihr Boot <span class="text-blue-300">in sicheren Händen</span>
          </h1>
          
          <p class="text-xl text-blue-100 max-w-xl">
            Professionelle Bootslagerung, sicheres Parking und innovative Keelcrab Rumpfreinigung in Preveza – Ihr Partner für den perfekten Bootsschutz.
          </p>
          
          <div class="flex flex-wrap gap-4">
            <a href="#leistungen" class="inline-flex items-center px-6 py-3 bg-white text-blue-900 font-semibold rounded-lg hover:bg-blue-50 transition-colors shadow-lg">
              Unsere Leistungen
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
            <a href="/kontakt" class="inline-flex items-center px-6 py-3 bg-blue-700 text-white font-semibold rounded-lg hover:bg-blue-600 transition-colors border border-blue-500">
              Termin vereinbaren
            </a>
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="relative">
            <div class="aspect-square rounded-2xl bg-gradient-to-br from-blue-400/20 to-blue-600/20 backdrop-blur-sm flex items-center justify-center border border-white/10">
              <!-- Placeholder for hero image -->
              <div class="text-center p-8">
                <div class="w-64 h-64 mx-auto bg-blue-800/50 rounded-full flex items-center justify-center border-4 border-blue-400/30">
                  <svg class="w-32 h-32 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <p class="mt-4 text-blue-200 text-sm">Bild: Keelcrab Rumpfreinigung</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section id="leistungen" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Unsere Leistungen</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Alles für Ihr Boot – von der sicheren Lagerung bis zur professionellen Unterwasser-Reinigung</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Storage -->
        <a href="/storage" class="group block">
          <div class="bg-gray-50 rounded-2xl p-8 h-full transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Storage</h3>
            <p class="text-gray-600 mb-4">Klimatisierte Trockenlagerung mit 24/7 Überwachung für maximale Sicherheit.</p>
            <span class="text-blue-600 font-medium flex items-center">
              Mehr erfahren
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Parking -->
        <a href="/parking" class="group block">
          <div class="bg-gray-50 rounded-2xl p-8 h-full transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
            <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 7m0 13V7"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Parking</h3>
            <p class="text-gray-600 mb-4">Sichere Stellplätze für Boote bis 8m – auch überdacht ab Winter 2026.</p>
            <span class="text-green-600 font-medium flex items-center">
              Mehr erfahren
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Service -->
        <a href="/service" class="group block">
          <div class="bg-gray-50 rounded-2xl p-8 h-full transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
            <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Service</h3>
            <p class="text-gray-600 mb-4">Professionelle Wartung und saisonale Inspektionen für Ihr Boot.</p>
            <span class="text-amber-600 font-medium flex items-center">
              Mehr erfahren
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Keelcrab -->
        <a href="/keelcrab" class="group block">
          <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-8 h-full transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1 border-2 border-blue-100">
            <div class="w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Keelcrab</span></h3>
            <p class="text-gray-600 mb-4">Innovative Rumpfreinigung im Wasser – ohne Heben, ohne Chemie, mit Ergebnis.</p>
            <span class="text-blue-600 font-medium flex items-center">
              Mehr erfahren
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Keelcrab Highlight -->
  <section class="py-20 bg-gradient-to-br from-blue-900 to-blue-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 bg-blue-700/50 rounded-full text-sm font-medium mb-6">
            Exklusiv in Griechenland
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Keelcrab – Die Zukunft der Rumpfreinigung</h2>
          
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p>Reinigung im Wasser – Ihr Boot bleibt liegen</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p>Keine Chemikalien – umweltfreundlich</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p>Schonend für Rumpfgelcoat</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p>Nur 800 Watt Stromverbrauch</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p>20-30% Kraftstoffeinsparung</p>
            </div>
          </div>

          <a href="/keelcrab" class="inline-flex items-center mt-8 px-6 py-3 bg-white text-blue-900 font-semibold rounded-lg hover:bg-blue-50 transition-colors">
            Alle Vorteile entdecken
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-blue-400/20 to-cyan-400/20 backdrop-blur-sm flex items-center justify-center border border-white/20">
            <!-- Placeholder for Keelcrab image -->
            <div class="text-center p-8">
              <div class="w-48 h-48 mx-auto bg-blue-800/50 rounded-2xl flex items-center justify-center border-2 border-blue-400/30">
                <svg class="w-24 h-24 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <p class="mt-4 text-blue-200">Bild: Keelcrab Maschine</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Häufige Fragen</h2>
        <p class="text-xl text-gray-600">Alles, was Sie über unsere Dienstleistungen wissen sollten</p>
      </div>

      <div class="space-y-4">
        <!-- FAQ Item 1 -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <button class="faq-toggle w-full flex justify-between items-center text-left" aria-expanded="false">
            <span class="font-semibold text-gray-900">Wie hoch sind die Preise für Storage?</span>
            <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-content hidden mt-4 text-gray-600">
            <p>Unsere Storage-Preise: <strong>38 €/m³ für Boxen</strong> und <strong>225 €/Monat für Autos (innen)</strong>. Die Mindestlaufzeit beträgt 1 Monat.</p>
          </div>
        </div>

        <!-- FAQ Item 2 -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <button class="faq-toggle w-full flex justify-between items-center text-left" aria-expanded="false">
            <span class="font-semibold text-gray-900">Wo genau befindet sich Captain Jack?</span>
            <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-content hidden mt-4 text-gray-600">
            <p>Wir befinden uns am <strong>Preveza Stadthafen</strong>, Leofóros Ioanninon 215. Ab nächster Woche haben wir auch einen zweiten Standort in der Preveza Marina.</p>
          </div>
        </div>

        <!-- FAQ Item 3 -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <button class="faq-toggle w-full flex justify-between items-center text-left" aria-expanded="false">
            <span class="font-semibold text-gray-900">Wie kann ich einen Termin für Keelcrab buchen?</span>
            <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-content hidden mt-4 text-gray-600">
            <p>Am einfachsten erreichen Sie uns per WhatsApp oder Telefon: <strong>Gosia +30 698 447 7868</strong>. Wir bieten auch mobilen Service an – wir kommen direkt zu Ihrem Boot, auch bei Ankerplätzen!</p>
          </div>
        </div>

        <!-- FAQ Item 4 -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <button class="faq-toggle w-full flex justify-between items-center text-left" aria-expanded="false">
            <span class="font-semibold text-gray-900">Wie lange dauert die Keelcrab-Reinigung?</span>
            <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-content hidden mt-4 text-gray-600">
            <p>Die Reinigung dauert ca. <strong>1-3 Stunden</strong>, je nach Bootslänge und Verschmutzungsgrad. Der Preis wird nach Länge berechnet, nicht nach Stunde.</p>
          </div>
        </div>

        <!-- FAQ Item 5 -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <button class="faq-toggle w-full flex justify-between items-center text-left" aria-expanded="false">
            <span class="font-semibold text-gray-900">Bietet ihr Service auch für Charterflotten an?</span>
            <svg class="faq-icon w-5 h-5 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-content hidden mt-4 text-gray-600">
            <p>Ja! Für Charter Companies bieten wir <strong>Sonderkonditionen</strong> an. Unser Keelcrab-Service ist ideal für Flotten – superschnell und effizient.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Bereit für Ihren Termin?</h2>
      <p class="text-xl text-gray-600 mb-8">Kontaktieren Sie Gosia direkt – wir freuen uns auf Ihr Boot!</p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-lg">
          <svg class="mr-2 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          +30 698 447 7868
        </a>
        <a href="https://wa.me/306984477868" target="_blank" rel="noopener" class="inline-flex items-center px-8 py-4 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors shadow-lg">
          <svg class="mr-2 w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 5.834h-.004a9.311 9.311 0 01-21-21c0-3.026.987-5.828 2.657-8.1l-1.423-5.618 5.649 1.42A9.293 9.293 0 0112 2a9.293 9.293 0 019.293 9.293 9.311 9.311 0 01-9.293 9.292z"/>
          </svg>
          WhatsApp schreiben
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // FAQ Accordion
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const icon = button.querySelector('.faq-icon');
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        button.setAttribute('aria-expanded', !isExpanded);
        content?.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      });
    });
  </script>
</Layout>