  <script>
    // FAQ Accordion
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const icon = button.querySelector('.faq-icon');
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        button.setAttribute('aria-expanded', !isExpanded);
        content?.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      });
    });

    // Solution buttons — toggle between alert (red) and resolved (green)
    document.querySelectorAll('.solution-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const target = document.getElementById(targetId);
        if (target) {
          target.classList.toggle('hidden');
          const isHidden = target.classList.contains('hidden');
          btn.textContent = isHidden ? 'Lösung anzeigen' : 'Lösung ausblenden';
          if (isHidden) {
            btn.classList.remove('btn-alert-resolved');
            btn.classList.add('btn-alert');
          } else {
            btn.classList.remove('btn-alert');
            btn.classList.add('btn-alert-resolved');
          }
        }
      });
    });
  </script>
