---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import captain from '../assets/images/captain.jpg';
import ourStore from '../assets/images/our_store.jpg';
import ourStore2 from '../assets/images/our_store_2.jpg';
import cars from '../assets/images/cars.jpg';
import ourLounge from '../assets/images/our_lounge.jpg';
import ourHome from '../assets/images/our_home.jpg';
import saschaAndGoshia from '../assets/images/sascha_and_goshia.jpg';
import saschaWithCaptain from '../assets/images/sascha_with_captain.jpg';
import prevezaPromenade from '../assets/images/preveza_promenade.png';
import ourStoreAtNight from '../assets/images/our_store_at_night.jpg';
import keelcrabFront from '../assets/images/keelcrab_front.png';
import keelcrabOnBoat from '../assets/images/keelcrab_on_boat.png';
import keelcrabUnder from '../assets/images/keelcrab_under.png';
import keelcrabFrontalSunshine from '../assets/images/keelcrab_frontal_sunshine.png';
import captainJackStorageCar from '../assets/images/captain-jack_storage_car.JPG';
import logo from '../assets/images/captain-jack-logo.png';
---

<Layout title="Bootslagerung & Keelcrab Service Preveza" description="Captain Jack - Moderne Bootslagerung und smarter Bootsservice in Preveza. Exklusive Keelcrab®-Technologie in Griechenland.">

  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden min-h-[600px] flex items-center">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ourStoreAtNight} 
        alt="Captain Jack Anlage bei Nacht" 
        class="w-full h-full object-cover"
        width={1920}
        height={800}
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0A2540]/90 via-[#0A2540]/70 to-transparent"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <!-- Left: Text Content -->
        <div class="max-w-3xl text-left flex-1">
        <!-- Badge -->
        <div class="inline-flex items-center px-3 py-1.5 bg-amber-500/15 border border-amber-500/40 rounded-full text-sm font-medium text-amber-400">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          200+ zufriedene Bootsbesitzer
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">
          Moderne Bootslagerung und smarter Bootsservice in Preveza
        </h1>
        
        <p class="text-lg text-slate-300 mb-6 max-w-2xl">
          Bootslagerung & Keelcrab® Unterwasserreinigung in Preveza. Ohne Kran, ohne Wartezeit – direkt im Wasser.
        </p>
        
        <!-- Badge -->
        <div class="inline-flex items-center px-3 py-1.5 bg-[#00c2d1]/15 border border-[#00c2d1]/40 rounded-full text-sm font-medium text-[#00c2d1]">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Exklusive Keelcrab®-Technologie in Griechenland
        </div>
      </div>

      <!-- Right: Logo -->
      <div class="hidden lg:flex flex-shrink-0 items-center justify-center">
        <div class="w-80 h-80 relative">
          <Image 
            src={logo} 
            alt="Captain Jack Logo" 
            class="w-full h-full object-contain drop-shadow-2xl"
            width={400}
            height={400}
            loading="eager"
          />
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- Service Cards -->
  <section id="services" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Unsere Leistungen</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Leistungsüberblick</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Alles rund um Ihr Boot – von der Lagerung bis zur modernen Unterwasserreinigung.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Storage -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-[#00c2d1]/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Storage</h3>
          <p class="text-gray-600 mb-4">Sichere Trockenlagerung mit 24/7 Überwachung und klimatisierter Lagerhalle.</p>
          <a href="#storage-section" class="link flex items-center">
            Mehr erfahren <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Parking -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-[#00c2d1]/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Parking</h3>
          <p class="text-gray-600 mb-4">Überdachte Stellplätze für Boote und Camper mit direktem Hafenzugang.</p>
          <a href="#parking-section" class="link flex items-center">
            Mehr erfahren <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Service -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-[#00c2d1]/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826 2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Service</h3>
          <p class="text-gray-600 mb-4">Professionelle Wartung, Reparaturen und saisonale Inspektionen vor Ort.</p>
          <a href="#service-section" class="link flex items-center">
            Mehr erfahren <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Technologie -->
        <div class="bg-gradient-to-br from-[#00c2d1]/5 to-[#00c2d1]/10 rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow border border-[#00c2d1]/20">
          <div class="w-12 h-12 bg-[#00c2d1] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Technologie</h3>
          <p class="text-gray-600 mb-4">Keelcrab® Unterwasserreinigung und Drohnen-Inspektion mit Live-Bericht.</p>
          <a href="#keelcrab" class="link flex items-center">
            Mehr erfahren <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem-Solution Section -->
  <section class="py-16" style="background: linear-gradient(135deg, #0A2540 0%, #1a3a5c 50%, #0d2b3a 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Kennen Sie das?</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Bootsbesitzer kennen diese Herausforderungen</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Problem 1 -->
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/10">
          <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Kein sicherer Stellplatz</h3>
          <p class="text-white/70 mb-6">Der Heimathafen ist überfüllt, Trockendocks kostspielig. Wo lässt sich mein Boot wirklich gut aufbewahren?</p>
          <button class="solution-btn btn-alert px-6 py-3" data-target="solution-1">
            Lösung anzeigen
          </button>
          <div id="solution-1" class="hidden mt-6 p-4 bg-white/10 backdrop-blur-sm rounded-lg text-white/90 text-sm border border-white/10">
            Unsere klimatisierte Lagerhalle mit 24/7 Überwachung bietet maximalen Schutz für Ihr Boot.
          </div>
        </div>

        <!-- Problem 2 -->
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/10">
          <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Rumpf voller Bewuchs</h3>
          <p class="text-white/70 mb-6">Kran-Termine dauern Wochen. Der Rumpf verrottet im Hafen. Reinigen ist teuer und zeitaufwendig.</p>
          <button class="solution-btn btn-alert px-6 py-3" data-target="solution-2">
            Lösung anzeigen
          </button>
          <div id="solution-2" class="hidden mt-6 p-4 bg-white/10 backdrop-blur-sm rounded-lg text-white/90 text-sm border border-white/10">
            Keelcrab® reinigt direkt im Wasser – ohne Kran, ohne Wartezeit, bis zu 70% günstiger als traditionelle Methoden.
          </div>
        </div>

        <!-- Problem 3 -->
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center border border-white/10">
          <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Viele Anbieter, kein Überblick</h3>
          <p class="text-white/70 mb-6">Lager hier, Service dort, Dokumentation woanders. Fragmentierte Betreuung statt ganzheitlicher Lösung.</p>
          <button class="solution-btn btn-alert px-6 py-3" data-target="solution-3">
            Lösung anzeigen
          </button>
          <div id="solution-3" class="hidden mt-6 p-4 bg-white/10 backdrop-blur-sm rounded-lg text-white/90 text-sm border border-white/10">
            Bei Captain Jack bekommen Sie alles aus einer Hand: Lagerung, Service, Reinigung und digitale Dokumentation.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USP Section (Keelcrab) -->
  <section id="keelcrab" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <!-- Subline -->
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Modernste Technik</p>
          
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Keelcrab® – Revolutionär einfach</h2>
          
          <p class="text-gray-600 text-lg mb-6">
            Die weltweit erste automatische Unterwasserreinigung für Yachten. Direkt am Liegeplatz – ohne Kran, ohne Trockendock, ohne Wartezeit.
          </p>

          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700">Filter in Keelcrab, kein Microplastic ins Wasser</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700">Reinigung im Wasser, Boot bleibt liegen</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700">Bis zu 70% günstiger als konventionelle Methoden</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700">Keine Chemikalien notwendig – umweltfreundlich</span>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-700">Schonend für Rumpfgelcoat und Umwelt</span>
            </li>
          </ul>

          <!-- CTAs -->
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/kontakt" class="btn-primary btn-primary-md">
              Kontakt aufnehmen
            </a>
            <a href="#video" class="btn-secondary btn-secondary-md">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
              </svg>
              Video ansehen
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <Image 
              src={keelcrabFront} 
              alt="Keelcrab Unterwasserreinigungsgerät" 
              class="w-full h-auto object-cover"
              width={600}
              height={800}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Keelcrab Video + Benefits -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Live Erleben</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Keelcrab in Action</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Sehen Sie selbst, wie die revolutionäre Technologie Ihren Bootsrumpf reinigt – direkt im Wasser, ohne Austrocknen.</p>
      </div>

      <!-- Video Embed -->
      <div class="max-w-4xl mx-auto mb-16">
        <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
          <iframe 
            src="https://www.youtube.com/embed/4DRgeDxJmjI" 
            title="Keelcrab in Action"
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            class="w-full h-full">
          </iframe>
        </div>
      </div>

      <!-- 4 Benefits -->
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Ihre Vorteile mit Keelcrab®</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-[#00c2d1]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 !font-sans">Schonend fürs Gelcoat</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-[#00c2d1]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 !font-sans">75% günstiger</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-[#00c2d1]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 !font-sans">Volle Sichtbarkeit</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-[#00c2d1]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-[#00c2d1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 !font-sans">Sofort einsatzbereit</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Exklusiv in Griechenland Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Content -->
        <div>
          <p class="text-[#00c2d1] text-sm font-medium tracking-wider uppercase mb-3">Exklusiv in Griechenland</p>
