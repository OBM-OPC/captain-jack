---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Bootslagerung & Keelcrab Service Preveza" description="Captain Jack - Moderne Bootslagerung und smarter Bootsservice in Preveza. Exklusive Keelcrab®-Technologie in Griechenland.">
  <!-- Header -->
  <header class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <!-- Logo - higher positioned -->
        <a href="/" class="flex items-center -mt-2">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-800 rounded-full flex items-center justify-center shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2.5 8.5l2.5 3.5L9 9l4 6 3.5-2.5L22 19"></path>
              <path d="M22 13a9 9 0 1 1-9-9 9 9 0 0 1 9 9Z"></path>
              <path d="M7 4h10v3H7z"></path>
            </svg>
          </div>
          <span class="ml-3 text-xl font-bold text-gray-900">Captain Jack</span>
        </a>

        <!-- Phone number -->
        <a href="tel:+302682012345" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="font-medium">+30 26820 12345</span>
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center opacity-10"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium text-blue-200 mb-6">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          200+ zufriedene Bootsbesitzer
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Moderne Bootslagerung und smarter Bootsservice in Preveza
        </h1>
        
        <p class="text-xl text-slate-300 mb-8 max-w-2xl mx-auto">
          Bootslagerung & Keelcrab® Unterwasserreinigung in Preveza. Ohne Kran, ohne Wartezeit – direkt im Wasser.
        </p>
        
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium text-amber-300">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Exklusive Keelcrab®-Technologie in Griechenland
        </div>
      </div>
    </div>
  </section>

  <!-- Service Cards -->
  <section id="services" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Storage -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Storage</h3>
          <p class="text-gray-600 mb-4">Sichere Trockenlagerung mit 24/7 Überwachung und klimatisierter Lagerhalle.</p>
          <a href="#storage-section" class="text-blue-600 font-medium flex items-center hover:text-blue-700">
            Mehr erfahren →
          </a>
        </div>

        <!-- Parking -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Parking</h3>
          <p class="text-gray-600 mb-4">Überdachte Stellplätze für Boote und Camper mit direktem Hafenzugang.</p>
          <a href="#parking-section" class="text-blue-600 font-medium flex items-center hover:text-blue-700">
            Mehr erfahren →
          </a>
        </div>

        <!-- Service -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826 2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Service</h3>
          <p class="text-gray-600 mb-4">Professionelle Wartung, Reparaturen und saisonale Inspektionen vor Ort.</p>
          <a href="#service-section" class="text-blue-600 font-medium flex items-center hover:text-blue-700">
            Mehr erfahren →
          </a>
        </div>

        <!-- Technologie -->
        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow border border-blue-100">
          <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Technologie</h3>
          <p class="text-gray-600 mb-4">Keelcrab® Unterwasserreinigung und Drohnen-Inspektion mit Live-Bericht.</p>
          <a href="#keelcrab" class="text-blue-600 font-medium flex items-center hover:text-blue-700">
            Mehr erfahren →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem-Solution Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Problem 1 -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Kein sicherer Stellplatz</h3>
          <p class="text-gray-600 mb-6">Der Heimathafen ist überfüllt, Trockendocks kostspielig. Wo lässt sich mein Boot wirklich gut aufbewahren?</p>
          <button class="solution-btn px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors" data-target="solution-1">
            Lösung anzeigen
          </button>
          <div id="solution-1" class="hidden mt-6 p-4 bg-amber-50 rounded-lg text-amber-800 text-sm">
            Unsere klimatisierte Lagerhalle mit 24/7 Überwachung bietet maximalen Schutz für Ihr Boot.
          </div>
        </div>

        <!-- Problem 2 -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Rumpf voller Bewuchs</h3>
          <p class="text-gray-600 mb-6">Kran-Termine dauern Wochen. Der Rumpf verrottet im Hafen. Reinigen ist teuer und zeitaufwendig.</p>
          <button class="solution-btn px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors" data-target="solution-2">
            Lösung anzeigen
          </button>
          <div id="solution-2" class="hidden mt-6 p-4 bg-amber-50 rounded-lg text-amber-800 text-sm">
            Keelcrab® reinigt direkt im Wasser – ohne Kran, ohne Wartezeit, bis zu 70% günstiger als traditionelle Methoden.
          </div>
        </div>

        <!-- Problem 3 -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Viele Anbieter, kein Überblick</h3>
          <p class="text-gray-600 mb-6">Lager hier, Service dort, Dokumentation woanders. Fragmentierte Betreuung statt ganzheitlicher Lösung.</p>
          <button class="solution-btn px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors" data-target="solution-3">
            Lösung anzeigen
          </button>
          <div id="solution-3" class="hidden mt-6 p-4 bg-amber-50 rounded-lg text-amber-800 text-sm">
            Bei Captain Jack bekommen Sie alles aus einer Hand: Lagerung, Service, Reinigung und digitale Dokumentation.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USP Section (Keelcrab) -->
  <section id="keelcrab" class="py-20 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium text-blue-200 mb-6">
            Unser USP
          </div>
          
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Keelcrab® – Revolutionär einfach</h2>
          
          <p class="text-slate-300 text-lg mb-8">
            Die weltweit erste automatische Unterwasserreinigung für Yachten. Direkt am Liegeplatz – ohne Kran, ohne Trockendock, ohne Wartezeit.
          </p>

          <ul class="space-y-4">
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-emerald-500 rounded-full flex-shrink-0 flex items-center justify-center mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span>Reinigung im Wasser, Boot bleibt liegen</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-emerald-500 rounded-full flex-shrink-0 flex items-center justify-center mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span>Bis zu 70% günstiger als konventionelle Methoden</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-emerald-500 rounded-full flex-shrink-0 flex items-center justify-center mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span>Keine Chemikalien notwendig – umweltfreundlich</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-emerald-500 rounded-full flex-shrink-0 flex items-center justify-center mt-1">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span>Schonend für Rumpfgelcoat und Umwelt</span>
            </li>
          </ul>

          <!-- Badge -->
          <div class="mt-8 inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium text-amber-300">
            Exklusiv in Preveza
          </div>
        </div>

        <div class="relative">
          <div class="aspect-square rounded-2xl bg-gradient-to-br from-blue-400/20 to-cyan-400/20 backdrop-blur-sm flex items-center justify-center border border-white/10">
            <div class="text-center p-8">
              <div class="w-48 h-48 mx-auto bg-blue-800/50 rounded-2xl flex items-center justify-center border-2 border-blue-400/30">
                <svg class="w-24 h-24 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <p class="mt-4 text-slate-400 text-sm">Keelcrab® Technologie</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 Feature Icons -->
  <section class="py-16 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Schonend fürs Gelcoat</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">75% günstiger</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Volle Sichtbarkeit</h4>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Sofort einsatzbereit</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Exklusiv in Griechenland Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center px-4 py-2 bg-blue-100 rounded-full text-sm font-medium text-blue-700 mb-6">
          Exklusiv in Griechenland
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Ihr exklusiver Keelcrab® Partner in Preveza</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Als einer der wenigen autorisierten Keelcrab® Partner in ganz Griechenland bieten wir Ihnen Zugang zu revolutionärer Unterwasserreinigungstechnologie – direkt hier in Preveza.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Autorisierter Partner</h4>
          <p class="text-sm text-gray-600">Zertifizierte Keelcrab® Technologie</p>
        </div>

        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Ideale Lage</h4>
          <p class="text-sm text-gray-600">Direkt in der Marina von Preveza</p>
        </div>

        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-12 h-12 bg-cyan-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Ionische Küste</h4>
          <p class="text-sm text-gray-600">Perfekte Bedingungen für Bootsreinigung</p>
        </div>

        <div class="bg-white rounded-xl p-6 text-center shadow-sm">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mx-auto mb-4">
