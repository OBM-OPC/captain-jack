---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Parking" description="Sichere Stellplätze für Boote in Preveza. 125 €/Monat, auch überdacht ab Winter 2026.">
  <Navigation />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-sm font-medium mb-6 text-amber-300">
          Sichere Außenstellplätze
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Parking</h1>
        <p class="text-xl text-blue-100">Freie Stellplätze für Ihr Boot im Herzen von Preveza – sicher und günstig.</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-video rounded-2xl bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center">
            <div class="text-center">
              <div class="w-32 h-32 mx-auto bg-white/50 rounded-2xl flex items-center justify-center">
                <svg class="w-16 h-16 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 7m0 13V7"/>
                </svg>
              </div>
              <p class="mt-4 text-gray-500">Bild: Stellplätze (kommt vom Kunden)</p>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Boots-Parking in Preveza</h2>
          
          <p class="text-gray-600 mb-6">Unsere Stellplätze bieten die ideale Lösung für Bootsbesitzer, die ihren Liegeplatz suchen. Gut zugänglich, sicher gelegen und nah am Wasser.</p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Zentrale Lage</h3>
                <p class="text-gray-600">Direkt am Preveza Stadthafen – kurze Wege zum Wasser.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-4l5-5M6 6l-5-5"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Für Boote bis 8m</h3>
                <p class="text-gray-600">Maximale Bootslänge: 7-8 Meter.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 6h4"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Auch für Camper</h3>
                <p class="text-gray-600">Stellplätze für Wohnmobile auf Anfrage verfügbar.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Preise</h2>
        <p class="text-xl text-gray-600">Günstige Konditionen für Ihr Boot</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Open Parking -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-amber-100 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900">Boots-Stellplatz</h3>
          </div>
          
          <div class="text-center">
            <div class="text-4xl font-bold text-amber-600 mb-2">125 €</div>
            <p class="text-gray-500">pro Monat / Boot</p>
          </div>
          
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Max. 7-8m Länge
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Zentrale Lage
            </li>
            <li class="flex items-center gap-3 text-gray-600">
              <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Mindestlaufzeit: 1 Monat
            </li>
          </ul>
        </div>

        <!-- Covered Parking (Coming Soon) -->
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-2xl p-8 shadow-lg border-2 border-amber-200 relative">
          <div class="absolute top-0 right-0 bg-amber-500 text-white text-sm font-semibold px-4 py-1 rounded-bl-lg rounded-tr-2xl">
            Ab Winter 2026
          </div>
          
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-amber-500 rounded-full mx-auto flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900">Überdachte Stellplätze</h3>
          </div>
          
          <div class="text-center">
            <div class="text-4xl font-bold text-amber-600 mb-2">Demnächst</div>
            <p class="text-gray-500">Verfügbar ab Winter 2026</p>
          </div>
          
          <div class="mt-6 text-center">
            <p class="text-sm text-gray-600 mb-4">Perfekt für die Winterzeit – schützen Sie Ihr Boot vor Witterungseinflüssen.</p>
            <a href="/kontakt" class="inline-flex items-center text-amber-600 font-medium hover:text-amber-700">
              Interesse anmelden
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Unsere Standorte</h2>
          
          <div class="space-y-6">
            <div class="bg-gray-50 rounded-xl p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold">Hauptstandort</h3>
              </div>
              <p class="text-gray-600">Leofóros Ioanninon 215<br/>Preveza Stadthafen</p>
            </div>

            <div class="bg-blue-50 rounded-xl p-6 border border-blue-100">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold">Zweiter Standort (ab nächste Woche)</h3>
              </div>
              <p class="text-gray-600">Preveza Marina</p>
            </div>
          </div>
        </div>

        <div class="aspect-square rounded-2xl bg-gray-100 flex items-center justify-center">
          <!-- Placeholder for Map -->
          <div class="text-center p-8">
            <div class="w-24 h-24 mx-auto bg-gray-300 rounded-full flex items-center justify-center mb-4">
              <svg class="w-12 h-12 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <p class="text-gray-500">Google Maps wird hier eingebunden</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-3xl font-bold mb-6">Reservieren Sie Ihren Stellplatz!</h2>
      <p class="text-xl text-blue-100 mb-8">Begrenzte Plätze verfügbar – jetzt anfragen!</p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+306984477868" class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
          Jetzt anrufen
        </a>
        <a href="https://wa.me/306984477868" target="_blank" rel="noopener" class="inline-flex items-center px-8 py-4 bg-amber-500 text-white font-semibold rounded-lg hover:bg-amber-600 transition-colors">
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
