---
import { Image } from "astro:assets";
import captainJackLogo from "../assets/images/captain-jack-logo.png";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/ueber-uns", label: "Über uns" },
  { href: "/leistungen", label: "Leistungen" },
  { href: "/keelcrab", label: "Keelcrab®" },
  { href: "/impressionen", label: "Impressionen" },
  { href: "/kontakt", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent transition-all duration-300">
  <div id="nav-shell" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 transition-all duration-300">
    <div id="nav-inner" class="flex h-24 items-center justify-between transition-all duration-300 lg:h-28">
      <a href="/" class="flex items-center gap-3 group">
        <Image
          id="nav-logo"
          src={captainJackLogo}
          alt="Captain Jack Logo"
          width={56}
          height={56}
          class="h-12 w-12 object-contain transition-all duration-300 lg:h-14 lg:w-14"
        />
        <span id="nav-brand" class="text-[1.7rem] font-bold tracking-wide text-white transition-all duration-300 lg:text-[1.95rem]" style="font-family: 'Cinzel', serif;">Captain Jack</span>
      </a>

      <div id="nav-links" class="hidden items-center gap-8 md:flex">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class={`text-sm font-medium transition-colors duration-150 ${
              currentPath === link.href 
                ? "text-[#00c2d1]" 
                : "text-white/85 hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="hidden md:block">
        <a 
          id="nav-cta"
          href="/kontakt" 
          class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white px-6 py-3 text-sm font-medium text-[#0A2540] shadow-sm transition-all duration-300 hover:border-white hover:bg-white/90 hover:text-[#0A2540] active:scale-[0.97]"
        >
          Kontakt
        </a>
      </div>

      <button 
        id="mobile-menu-btn" 
        class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-white/20 bg-white/10 text-white shadow-sm backdrop-blur-sm transition-all duration-300 hover:bg-white/15 md:hidden" 
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden pb-4 md:hidden">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-xl shadow-slate-200/60">
        <div class="border-b border-slate-100 bg-gradient-to-r from-[#0A2540] to-slate-800 px-5 py-5 text-white">
          <p class="text-lg font-semibold">Navigation</p>
          <p class="mt-1 text-sm text-slate-300">Schnell zu den wichtigsten Bereichen.</p>
        </div>

        <div class="space-y-2 p-3">
          {navLinks.map((link) => (
            <a 
              href={link.href} 
              class={`flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition-all ${
                currentPath === link.href
                  ? "bg-[#00c2d1]/10 text-[#00c2d1]"
                  : "text-gray-700 hover:bg-slate-50"
              }`}
            >
              <span>{link.label}</span>
              <svg class="h-4 w-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>

        <div class="border-t border-slate-100 bg-slate-50 p-4">
          <div class="grid grid-cols-1 gap-3">
            <a href="/kontakt" class="btn-primary btn-primary-md w-full">Jetzt Kontakt aufnehmen</a>
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-gray-600">
              <p class="font-semibold text-[#0A2540]">Direkt erreichbar</p>
              <div class="mt-2 space-y-1">
                <a href="tel:+491754271476" class="block hover:text-[#00c2d1]">+49 175 4271476</a>
                <a href="tel:+306984477868" class="block hover:text-[#00c2d1]">+30 698 447 7868</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const navInner = document.getElementById('nav-inner');
  const navBrand = document.getElementById('nav-brand');
  const navLogo = document.getElementById('nav-logo');
  const navLinks = document.getElementById('nav-links');
  const navCta = document.getElementById('nav-cta');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  const syncMenuState = (expanded) => {
    btn?.setAttribute('aria-expanded', String(expanded));
    menu?.classList.toggle('hidden', !expanded);
    openIcon?.classList.toggle('hidden', expanded);
    closeIcon?.classList.toggle('hidden', !expanded);
  };

  const setScrolledState = () => {
    const isScrolled = window.scrollY > 40;

    nav?.classList.toggle('bg-white/95', isScrolled);
    nav?.classList.toggle('backdrop-blur-sm', isScrolled);
    nav?.classList.toggle('border-gray-100', isScrolled);
    nav?.classList.toggle('shadow-sm', isScrolled);
    nav?.classList.toggle('bg-transparent', !isScrolled);
    nav?.classList.toggle('border-transparent', !isScrolled);

    navInner?.classList.toggle('h-24', !isScrolled);
    navInner?.classList.toggle('lg:h-28', !isScrolled);
    navInner?.classList.toggle('h-18', isScrolled);
    navInner?.classList.toggle('lg:h-20', isScrolled);

    navBrand?.classList.toggle('text-white', !isScrolled);
    navBrand?.classList.toggle('text-[#0A2540]', isScrolled);
    navBrand?.classList.toggle('text-[1.7rem]', !isScrolled);
    navBrand?.classList.toggle('lg:text-[1.95rem]', !isScrolled);
    navBrand?.classList.toggle('text-[1.45rem]', isScrolled);
    navBrand?.classList.toggle('lg:text-[1.65rem]', isScrolled);

    navLogo?.classList.toggle('h-12', !isScrolled);
    navLogo?.classList.toggle('w-12', !isScrolled);
    navLogo?.classList.toggle('lg:h-14', !isScrolled);
    navLogo?.classList.toggle('lg:w-14', !isScrolled);
    navLogo?.classList.toggle('h-10', isScrolled);
    navLogo?.classList.toggle('w-10', isScrolled);
    navLogo?.classList.toggle('lg:h-11', isScrolled);
    navLogo?.classList.toggle('lg:w-11', isScrolled);

    btn?.classList.toggle('border-white/20', !isScrolled);
    btn?.classList.toggle('bg-white/10', !isScrolled);
    btn?.classList.toggle('text-white', !isScrolled);
    btn?.classList.toggle('border-slate-200', isScrolled);
    btn?.classList.toggle('bg-white', isScrolled);
    btn?.classList.toggle('text-gray-700', isScrolled);

    navCta?.classList.toggle('border-white/30', !isScrolled);
    navCta?.classList.toggle('bg-white', !isScrolled);
    navCta?.classList.toggle('text-[#0A2540]', !isScrolled);
    navCta?.classList.toggle('border-slate-200', isScrolled);
    navCta?.classList.toggle('bg-white', isScrolled);
    navCta?.classList.toggle('text-[#0A2540]', isScrolled);

    navLinks?.querySelectorAll('a').forEach((link) => {
      if (link.classList.contains('text-[#00c2d1]')) return;
      link.classList.toggle('text-white/85', !isScrolled);
      link.classList.toggle('hover:text-white', !isScrolled);
      link.classList.toggle('text-gray-600', isScrolled);
      link.classList.toggle('hover:text-gray-900', isScrolled);
    });
  };
  
  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    syncMenuState(!isExpanded);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => syncMenuState(false));
  });

  setScrolledState();
  window.addEventListener('scroll', setScrolledState, { passive: true });
</script>
