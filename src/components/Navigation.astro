---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/ueber-uns", label: "Über uns" },
  { href: "/leistungen", label: "Leistungen" },
  { href: "/keelcrab", label: "Keelcrab®" },
  { href: "/impressionen", label: "Impressionen" },
  { href: "/kontakt", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="bg-white border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <a href="/" class="flex items-center group">
        <span class="text-2xl font-bold text-[#0A2540] tracking-wide" style="font-family: 'Cinzel', serif;">Captain Jack</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class={`text-sm font-medium transition-colors duration-150 ${
              currentPath === link.href 
                ? "text-[#00c2d1]" 
                : "text-gray-600 hover:text-gray-900"
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="hidden md:block">
        <a 
          href="/kontakt" 
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#00c2d1] text-white text-sm font-medium rounded-lg hover:bg-[#00a8b5] transition-all duration-200 hover:shadow-md active:scale-[0.97]"
        >
          Kontakt
        </a>
      </div>

      <button 
        id="mobile-menu-btn" 
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" 
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-1">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class={`block px-4 py-3 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? "bg-[#00c2d1]/10 text-[#00c2d1]"
              : "text-gray-700 hover:bg-gray-50"
          }`}
        >
          {link.label}
        </a>
      ))}
      <a 
        href="/kontakt" 
        class="block px-4 py-3 text-sm font-medium text-[#00c2d1]"
      >
        Kontakt aufnehmen
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
  });
</script>
