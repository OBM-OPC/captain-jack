---
import { Image } from 'astro:assets';
import logo from '../assets/images/captain-jack-logo.png';

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/ueber-uns", label: "Über uns" },
  { href: "/leistungen", label: "Leistungen" },
  { href: "/keelcrab", label: "Keelcrab®" },
  { href: "/kontakt", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="bg-white border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo: Captain Jack in Cinzel -->
      <a href="/" class="flex items-center group">
        <span class="text-2xl font-bold text-[#0A2540] tracking-wide" style="font-family: 'Cinzel', serif;">Captain Jack</span>
      </a>

      <!-- Desktop Navigation + Logo rechts -->
      <div class="hidden md:flex items-center gap-6">
        <div class="flex items-center gap-8">
          {navLinks.map((link) => (
            <a 
              href={link.href} 
              class={`text-sm font-medium transition-colors duration-150 ${
                currentPath === link.href 
                  ? "text-[#00c2d1]" 
                  : "text-gray-600 hover:text-gray-900"
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Logo Image rechts, groß -->
        <div class="h-16 w-auto">
          <Image 
            src={logo} 
            alt="Captain Jack Logo" 
            class="h-full w-auto object-contain"
            width={200}
            height={64}
          />
        </div>
      </div>

      <!-- CTA Button (Desktop) -->
      <div class="hidden lg:block">
        <a 
          href="tel:+306984447868" 
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#00c2d1] text-white text-sm font-medium rounded-lg hover:bg-[#00a8b5] transition-all duration-200 hover:shadow-md active:scale-[0.97]"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Anrufen
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" 
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-1">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class={`block px-4 py-3 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? "bg-[#00c2d1]/10 text-[#00c2d1]"
              : "text-gray-700 hover:bg-gray-50"
          }`}
        >
          {link.label}
        </a>
      ))}
      <a 
        href="tel:+306984447868" 
        class="flex items-center gap-2 px-4 py-3 text-sm font-medium text-[#00c2d1]"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        +30 698 447 7868
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
  });
</script>
