---
import { Image } from "astro:assets";
import captainJackLogo from "../assets/images/captain-jack-logo.png";
---

<footer class="bg-slate-950 text-slate-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div>
        <div class="mb-4 flex flex-col items-start">
          <Image
            src={captainJackLogo}
            alt="Captain Jack Logo"
            width={88}
            height={88}
            class="mb-3 h-20 w-20 object-contain"
          />
          <span class="text-2xl font-bold tracking-wide text-white" style="font-family: 'Cinzel', serif;">Captain Jack</span>
        </div>
        <p class="text-sm text-slate-500">Bootslagerung & Keelcrab Service in Preveza, Griechenland.</p>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Navigation</span>
        <a href="/ueber-uns" class="link-dark">Über uns</a>
        <a href="/leistungen" class="link-dark">Leistungen</a>
        <a href="/keelcrab" class="link-dark">Keelcrab®</a>
        <a href="/kontakt" class="link-dark">Kontakt</a>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Kontakt</span>
        <span>Leofóros Ioanninon 215</span>
        <span>481 00 Preveza, Griechenland</span>
        <a href="tel:+491754271476" class="link-dark">+49 175 4271476</a>
        <a href="tel:+306984477868" class="link-dark">+30 698 447 7868</a>
        <a href="mailto:info@captain-jack.pro" class="link-dark">info@captain-jack.pro</a>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Rechtliches</span>
        <a href="/impressum" class="link-dark">Impressum</a>
        <a href="/datenschutz" class="link-dark">Datenschutz</a>
      </div>
    </div>
    <div class="border-t border-white/10 mt-8 pt-8 text-center text-sm">
      © 2026 Captain Jack. Alle Rechte vorbehalten.
    </div>
  </div>
</footer>