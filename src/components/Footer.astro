---
import { Image } from "astro:assets";
import captainJackLogo from "../assets/images/captain-jack-logo.png";
---

<footer class="bg-slate-950 text-slate-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div>
        <div class="mb-4 flex flex-col items-start">
          <Image
            src={captainJackLogo}
            alt="Captain Jack Logo"
            width={88}
            height={88}
            class="mb-3 h-20 w-20 object-contain"
          />
          <span class="text-2xl font-bold tracking-wide text-white">Captain Jack</span>
        </div>
        <p class="text-sm text-slate-500">Bootslagerung, Parking, Bootsreinigung und Service in Preveza, Griechenland.</p>
        <div class="mt-4 flex items-center gap-4">
          <a
            href="https://www.facebook.com/profile.php?id=61579890242632"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Captain Jack auf Facebook"
            class="text-slate-400 transition-colors hover:text-[#00c2d1]"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5 fill-current">
              <path d="M13.5 21v-8.2h2.8l.4-3.2h-3.2V7.5c0-.9.3-1.5 1.6-1.5h1.7V3.1c-.3 0-1.3-.1-2.5-.1-2.5 0-4.2 1.5-4.2 4.4v2.2H8v3.2h2.6V21h2.9Z" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/captain_jack_preveza"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Captain Jack auf Instagram"
            class="text-slate-400 transition-colors hover:text-[#00c2d1]"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5 fill-current">
              <path d="M7.5 3h9A4.5 4.5 0 0 1 21 7.5v9a4.5 4.5 0 0 1-4.5 4.5h-9A4.5 4.5 0 0 1 3 16.5v-9A4.5 4.5 0 0 1 7.5 3Zm0 1.8A2.7 2.7 0 0 0 4.8 7.5v9a2.7 2.7 0 0 0 2.7 2.7h9a2.7 2.7 0 0 0 2.7-2.7v-9a2.7 2.7 0 0 0-2.7-2.7h-9Zm9.45 1.35a1.05 1.05 0 1 1 0 2.1 1.05 1.05 0 0 1 0-2.1ZM12 7.8A4.2 4.2 0 1 1 7.8 12 4.2 4.2 0 0 1 12 7.8Zm0 1.8A2.4 2.4 0 1 0 14.4 12 2.4 2.4 0 0 0 12 9.6Z" />
            </svg>
          </a>
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Navigation</span>
        <a href="/ueber-uns" class="link-dark">Über uns</a>
        <a href="/leistungen" class="link-dark">Leistungen</a>
        <a href="/keelcrab" class="link-dark">Keelcrab®</a>
        <a href="/nachhaltige-bootsreinigung" class="link-dark">Nachhaltige Reinigung</a>
        <a href="/charterflotten-marinas" class="link-dark">Für Charterflotten & Marinas</a>
        <a href="/impressionen" class="link-dark">Impressionen</a>
        <a href="/kontakt" class="link-dark">Kontakt</a>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Kontakt</span>
        <span>Leofóros Ioanninon 215</span>
        <span>48100 Preveza, Griechenland</span>
        <a href="tel:+491754271476" class="link-dark">+49 175 4271476</a>
        <a href="tel:+306984477868" class="link-dark">+30 698 447 7868</a>
        <a href="mailto:bark@captain-jack.pro" class="link-dark">bark@captain-jack.pro</a>
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-semibold text-white">Rechtliches</span>
        <a href="/impressum" class="link-dark">Impressum</a>
        <a href="/datenschutz" class="link-dark">Datenschutz</a>
      </div>
    </div>
    <div class="border-t border-white/10 mt-8 pt-8 text-center text-sm">
      © 2026 Captain Jack. Alle Rechte vorbehalten.
    </div>
  </div>
</footer>
