---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import captainJackLogo from "../assets/images/captain-jack-logo.png";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Captain Jack - Bootslagerung & Keelcrab Service in Preveza, Griechenland",
  ogImage = captainJackLogo.src,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://captain-jack.pro").toString();
const pageTitle = `${title} | Captain Jack`;
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://captain-jack.pro").toString();
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Captain Jack',
  image: ogImageUrl,
  url: Astro.site ?? 'https://captain-jack.pro',
  telephone: ['+49 175 4271476', '+30 698 447 7868'],
  email: 'info@captain-jack.pro',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Leofóros Ioanninon 215',
    postalCode: '48100',
    addressLocality: 'Preveza',
    addressCountry: 'GR',
  },
};
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:locale" content="de_DE" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Captain Jack" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:alt" content="Captain Jack Logo" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <title>{pageTitle}</title>
  <link rel="icon" type="image/png" href={captainJackLogo.src} />
  <link rel="apple-touch-icon" href={captainJackLogo.src} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
  <style>
    :root {
      --font-headings: 'Cinzel', serif;
      --font-body: 'Inter', sans-serif;
    }
    body {
      font-family: var(--font-body);
    }
  </style>
</head>
<body class="font-['Inter'] bg-white text-gray-900 antialiased">
  <Navigation />
  <slot />
  <Footer />
</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
